---
import BaseLayout from '@ui/BaseLayout.astro';
import CategoryBadge from '@ui/CategoryBadge.astro';
import PortableText from '@ui/PortableText.astro';
import { getNoticias, getNoticia } from '@api/endpoints/noticias';

export const prerender = true;

export async function getStaticPaths() {
  const noticias = await getNoticias();
  return noticias.map((n) => ({ params: { slug: n.slug.current } }));
}

const { slug } = Astro.params;
const noticia = await getNoticia(slug);

if (!noticia) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

function formatDate(iso: string): string {
  return new Intl.DateTimeFormat('es-EC', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(new Date(iso));
}
---

<BaseLayout
  title={noticia.titulo}
  description={noticia.resumen}
  type="article"
  publishedAt={noticia.publishedAt}
  canonical={`https://antonio-ante.gob.ec/noticias/${noticia.slug.current}`}
>
  <!-- Hero de la noticia -->
  <section class="bg-brand-primary text-white py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-white/60 text-sm flex-wrap" role="list">
          <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="select-none">›</li>
          <li><a href="/noticias" class="hover:text-white transition-colors">Noticias</a></li>
          <li aria-hidden="true" class="select-none">›</li>
          <li class="text-white/80 truncate max-w-[200px]" aria-current="page">{noticia.titulo}</li>
        </ol>
      </nav>

      <div class="flex items-center gap-3 mb-4 flex-wrap">
        <CategoryBadge categoria={noticia.categoria} size="md" />
        {
          noticia.destacada && (
            <span class="px-3 py-1 bg-brand-secondary text-white text-sm font-bold rounded-full uppercase tracking-wide">
              Destacada
            </span>
          )
        }
      </div>

      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight mb-4">
        {noticia.titulo}
      </h1>

      <p class="text-white/80 text-lg leading-relaxed mb-6 max-w-2xl">
        {noticia.resumen}
      </p>

      <time
        datetime={noticia.publishedAt}
        class="inline-flex items-center gap-2 text-white/60 text-sm font-medium"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
          ></path>
        </svg>
        <span class="capitalize">{formatDate(noticia.publishedAt)}</span>
      </time>
    </div>
  </section>

  <!-- Cuerpo de la noticia -->
  <section class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12 items-start">
        <!-- Contenido principal -->
        <article aria-label="Contenido de la noticia">
          <PortableText blocks={noticia.cuerpo ?? []} class="max-w-prose" />
        </article>

        <!-- Sidebar -->
        <aside aria-label="Información adicional" class="lg:sticky lg:top-24 space-y-4">
          <div class="bg-brand-accent rounded-xl p-5 border border-gray-100">
            <h2 class="text-sm font-bold text-brand-primary uppercase tracking-wide mb-3">
              Información
            </h2>
            <dl class="space-y-3 text-sm">
              <div>
                <dt class="text-brand-dark/50 font-medium">Categoría</dt>
                <dd class="mt-0.5">
                  <CategoryBadge categoria={noticia.categoria} />
                </dd>
              </div>
              <div>
                <dt class="text-brand-dark/50 font-medium">Publicado</dt>
                <dd class="text-brand-dark font-semibold mt-0.5 capitalize">
                  {formatDate(noticia.publishedAt)}
                </dd>
              </div>
              <div>
                <dt class="text-brand-dark/50 font-medium">Fuente</dt>
                <dd class="text-brand-dark mt-0.5">GAD Municipal de Antonio Ante</dd>
              </div>
            </dl>
          </div>

          <a
            href="/noticias"
            class="flex items-center gap-2 text-sm font-semibold text-brand-primary hover:text-brand-secondary transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-brand-primary rounded p-1"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"></path>
            </svg>
            Volver a noticias
          </a>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
