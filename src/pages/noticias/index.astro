---
import BaseLayout from '@ui/BaseLayout.astro';
import Card from '@ui/Card.astro';
import CategoryBadge from '@ui/CategoryBadge.astro';
import { getNoticias } from '@api/endpoints/noticias';
import type { CategoriaNoticia } from '@lib/validations';

const noticias = await getNoticias();

function formatDate(iso: string): string {
  return new Intl.DateTimeFormat('es-EC', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(new Date(iso));
}

const categorias: { value: CategoriaNoticia | 'todas'; label: string }[] = [
  { value: 'todas', label: 'Todas' },
  { value: 'institucional', label: 'Institucional' },
  { value: 'obras', label: 'Obras' },
  { value: 'social', label: 'Social' },
  { value: 'cultura', label: 'Cultura' },
  { value: 'turismo', label: 'Turismo' },
  { value: 'deporte', label: 'Deporte' },
  { value: 'otro', label: 'Otro' },
];
---

<BaseLayout
  title="Noticias"
  description="Últimas noticias y novedades del Gobierno Autónomo Descentralizado Municipal del Cantón Antonio Ante, Imbabura, Ecuador."
>
  <!-- Hero sección -->
  <section class="bg-brand-primary text-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-white/60 text-sm" role="list">
          <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="select-none">›</li>
          <li class="text-white font-medium" aria-current="page">Noticias</li>
        </ol>
      </nav>
      <h1 class="text-3xl lg:text-4xl font-bold">Noticias del cantón</h1>
      <p class="mt-3 text-white/80 max-w-xl">
        Mantente informado con las últimas novedades institucionales, obras, cultura y más.
      </p>
    </div>
  </section>

  <section class="py-12 lg:py-16 bg-brand-light" aria-label="Listado de noticias">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filtros por categoría (client-side) -->
      <div class="mb-8" role="group" aria-label="Filtrar por categoría">
        <div class="flex flex-wrap gap-2" id="filter-buttons">
          {
            categorias.map(({ value, label }) => (
              <button
                type="button"
                data-filter={value}
                class:list={[
                  'px-3 py-1.5 rounded-full text-sm font-semibold border transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-brand-primary',
                  value === 'todas'
                    ? 'bg-brand-primary text-white border-brand-primary'
                    : 'bg-white text-brand-dark border-gray-200 hover:border-brand-primary hover:text-brand-primary',
                ]}
                aria-pressed={value === 'todas' ? 'true' : 'false'}
              >
                {label}
              </button>
            ))
          }
        </div>
      </div>

      {
        noticias.length === 0 ? (
          <div class="text-center py-20">
            <p class="text-brand-dark/50 text-lg">No hay noticias publicadas aún.</p>
          </div>
        ) : (
          <ul
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
            role="list"
            id="noticias-grid"
            aria-live="polite"
            aria-atomic="false"
          >
            {noticias.map((noticia) => (
              <li data-categoria={noticia.categoria}>
                <Card
                  as="article"
                  href={`/noticias/${noticia.slug.current}`}
                  linkLabel={noticia.titulo}
                  interactive
                  padding="none"
                >
                  <div class="p-5 flex flex-col h-full">
                    <div class="flex items-center gap-2 mb-3 flex-wrap">
                      <CategoryBadge categoria={noticia.categoria} />
                      {noticia.destacada && (
                        <span class="px-2 py-0.5 bg-brand-secondary/10 text-brand-primary text-xs font-bold rounded-full uppercase tracking-wide">
                          Destacada
                        </span>
                      )}
                      <time
                        datetime={noticia.publishedAt}
                        class="text-xs text-brand-dark/50 font-medium ml-auto"
                      >
                        {formatDate(noticia.publishedAt)}
                      </time>
                    </div>
                    <h2 class="text-base font-bold text-brand-primary leading-snug mb-2 line-clamp-2">
                      {noticia.titulo}
                    </h2>
                    <p class="text-sm text-brand-dark/70 leading-relaxed line-clamp-3 flex-1">
                      {noticia.resumen}
                    </p>
                    <p class="mt-4 text-xs font-semibold text-brand-primary flex items-center gap-1">
                      Leer nota completa
                      <svg
                        class="w-3.5 h-3.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </p>
                  </div>
                </Card>
              </li>
            ))}
          </ul>
        )
      }

      <!-- Estado vacío tras filtrado -->
      <p
        id="empty-filter-msg"
        class="hidden text-center py-16 text-brand-dark/50 text-lg"
        role="status"
      >
        No hay noticias en esta categoría.
      </p>
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const items = document.querySelectorAll<HTMLElement>('#noticias-grid li[data-categoria]');
  const emptyMsg = document.getElementById('empty-filter-msg');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'todas';

      // Update button states
      buttons.forEach((b) => {
        const active = b.dataset.filter === filter;
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
        b.className = b.className
          .replace(/bg-brand-primary text-white border-brand-primary/, '')
          .replace(
            /bg-white text-brand-dark border-gray-200 hover:border-brand-primary hover:text-brand-primary/,
            ''
          )
          .trim();
        if (active) {
          b.classList.add('bg-brand-primary', 'text-white', 'border-brand-primary');
        } else {
          b.classList.add(
            'bg-white',
            'text-brand-dark',
            'border-gray-200',
            'hover:border-brand-primary',
            'hover:text-brand-primary'
          );
        }
      });

      // Show/hide items
      let visible = 0;
      items.forEach((item) => {
        const match = filter === 'todas' || item.dataset.categoria === filter;
        item.hidden = !match;
        if (match) visible++;
      });

      if (emptyMsg) emptyMsg.classList.toggle('hidden', visible > 0);
    });
  });
</script>
