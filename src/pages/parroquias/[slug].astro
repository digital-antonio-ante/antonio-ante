      color 0.18s ease,
      border-color 0.18s ease;
    padding: 0;
  }
  .pp-gnav:hover {
    background: var(--color);
    color: white;
    border-color: var(--color);
  }
  .pp-gnav:focus-visible {
    outline: 3px solid var(--color);
    outline-offset: 2px;
  }
  .pp-gnav--prev {
    left: -13px;
  }
  .pp-gnav--next {
    right: -13px;
  }
  /* hidden attribute nativo oculta el botón cuando no hay más scroll */
  .pp-gnav[hidden] {
    display: none;
  }

  /* En mobile (<768px) la galería es grid, no necesita flechas */
  @media (max-width: 768px) {
    .pp-gnav {
      display: none !important;
    }
  }

  .pp-gallery-strip {
    display: flex;
    gap: 0.55rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
    /* width explícito + max-width garantizan que iOS Safari calcule
       la caja antes de aplicar overflow → los thumbs scrollean internamente */
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }
  .pp-gallery-strip::-webkit-scrollbar {
    display: none;
  }

  .pp-gallery-thumb {
    flex: 0 0 150px;
    height: 106px;
    border-radius: 10px;
    overflow: hidden;
    cursor: pointer;
    scroll-snap-align: start;
    padding: 0;
    border: 2.5px solid transparent;
    background: #e2e8f0;
    transition:
      border-color 0.2s ease,
      transform 0.22s ease;
  }
  .pp-gallery-thumb:hover {
    border-color: var(--color);
    transform: scale(1.04);
  }
  .pp-gallery-thumb:focus-visible {
    outline: 3px solid var(--color);
    outline-offset: 2px;
  }
  .pp-gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .pp-gnav,
    .pp-action-btn,
    .pp-back,
    .pp-gallery-thumb {
      transition: none;
    }
  }
</style>

<script>
  // Scroll reveal
  const io = new IntersectionObserver(
    (entries) =>
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      }),
    { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
  );
  document.querySelectorAll('.pp-reveal').forEach((el) => io.observe(el));
</script>

<script>
  // Galería — lightbox + flechas prev/next del strip
  import { openGallery } from '../../modules/canton/ui/canton-gallery';

  const dataEl = document.getElementById('parish-gallery-data');
  if (dataEl?.textContent) {
    const { name, images, color } = JSON.parse(dataEl.textContent) as {
      name: string;
      images: string[];
      color: string;
    };
    document.querySelectorAll<HTMLButtonElement>('[data-gallery-index]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.dataset.galleryIndex ?? '0', 10);
        openGallery(name, images, color, idx);
      });
    });
  }

  // Flechas de navegación del strip (solo activas en modo scroll, >768px)
  const strip = document.querySelector<HTMLElement>('.pp-gallery-strip');
  const prevBtn = document.querySelector<HTMLButtonElement>('.pp-gnav--prev');
  const nextBtn = document.querySelector<HTMLButtonElement>('.pp-gnav--next');

  if (strip && prevBtn && nextBtn) {
    const STEP = 160; // ~ancho de un thumb + gap

    const sync = () => {
      const atStart = strip.scrollLeft <= 2;
      const atEnd = strip.scrollLeft >= strip.scrollWidth - strip.clientWidth - 2;
      prevBtn.hidden = atStart;
      nextBtn.hidden = atEnd;
    };

    prevBtn.addEventListener('click', () => strip.scrollBy({ left: -STEP, behavior: 'smooth' }));
    nextBtn.addEventListener('click', () => strip.scrollBy({ left: STEP, behavior: 'smooth' }));

    strip.addEventListener('scroll', sync, { passive: true });

    // Estado inicial y también cuando la ventana cambia de tamaño
    sync();
    window.addEventListener('resize', sync, { passive: true });
  }
</script>
