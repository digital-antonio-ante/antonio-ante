---
import BaseLayout from '@ui/BaseLayout.astro';
import PortableText from '@ui/PortableText.astro';
import CantonGallery from '@modules/canton/ui/CantonGallery.astro';
import { getParroquias, getParroquia } from '@api/endpoints/parroquias';
import { getObrasByParroquia } from '@api/endpoints/obras';
import { PARISHES } from '@modules/canton/data/parishes';

export const prerender = true;

export async function getStaticPaths() {
  const parroquias = await getParroquias();
  return parroquias.map((p) => ({ params: { slug: p.slug.current } }));
}

const { slug } = Astro.params;
const parroquia = await getParroquia(slug);

if (!parroquia) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const parishKey = slug.replaceAll('-', '_');
const staticData = PARISHES[parishKey] ?? null;

function cropUrl(base: string, w: number, h: number, fx: number, fy: number): string {
  return `${base}?w=${w}&h=${h}&fit=crop&fp-x=${fx.toFixed(3)}&fp-y=${fy.toFixed(3)}&auto=format&q=80`;
}

const hx = parroquia.hotspotX ?? 0.5;
const hy = parroquia.hotspotY ?? 0.5;

// Panel derecho: cubre alto del hero (~220px) y ~36vw de ancho → crop 3:2
const panelSrc = parroquia.imageUrl ? cropUrl(parroquia.imageUrl, 960, 640, hx, hy) : null;
const panelSrcset = parroquia.imageUrl
  ? [480, 640, 960, 1200]
      .map((w) => {
        const h = Math.round(w * (640 / 960));
        return `${parroquia.imageUrl}?w=${w}&h=${h}&fit=crop&fp-x=${hx.toFixed(3)}&fp-y=${hy.toFixed(3)}&auto=format&q=88 ${w}w`;
      })
      .join(', ')
  : null;
// OG siempre 1200×630 (estándar)
const ogSrc = parroquia.imageUrl ? cropUrl(parroquia.imageUrl, 1200, 630, hx, hy) : null;

const obras = await getObrasByParroquia(parroquia.nombre);

const color = staticData?.color ?? '#277816';

// Galería: fotos subidas en Sanity — thumbnail 320×220, original para lightbox
const galeriaFotos = (parroquia.galeria ?? []).filter((f) => !!f.url);
const galleryImages = galeriaFotos.map((f) => `${f.url}?auto=format&q=90`);
const galleryThumbs = galeriaFotos.map((f) => `${f.url}?w=320&h=220&fit=crop&auto=format&q=82`);

const activityEmojis: Record<string, string> = {
  'Industria Textil': '🧵',
  Comercio: '🛒',
  Gastronomía: '🍽️',
  'Turismo Histórico': '🏛️',
  Educación: '📚',
  Servicios: '⚙️',
  Turismo: '🗺️',
  Agricultura: '🌾',
  Cultura: '🎭',
  Música: '🎺',
  Artesanía: '🏺',
  Ecoturismo: '🌿',
  'Pesca Deportiva': '🎣',
  Salud: '🏥',
  Deporte: '⚽',
};
const mapIcon = staticData?.mapIcon ?? '📍';
const shortDesc = staticData?.shortDesc ?? null;
const activities = staticData?.activities ?? [];

const altitude = staticData?.altitude ?? null;

const tipoDisplay = parroquia.esCabeceraCantonal
  ? 'Cabecera cantonal · Urbana'
  : (staticData?.type ?? 'Rural');

const seoTitle = shortDesc ? `${parroquia.nombre} — ${shortDesc}` : parroquia.nombre;

const seoDesc = shortDesc
  ? `${parroquia.nombre} — ${shortDesc}. Parroquia del Cantón Antonio Ante, Imbabura, Ecuador.`
  : `Información sobre ${parroquia.nombre}, parroquia del Cantón Antonio Ante, Imbabura, Ecuador.`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'AdministrativeArea',
  name: parroquia.nombre,
  url: `https://antonio-ante.gob.ec/parroquias/${parroquia.slug.current}`,
  ...(staticData?.description ? { description: staticData.description } : {}),
  ...(ogSrc ? { image: ogSrc } : {}),
  containedInPlace: {
    '@type': 'AdministrativeArea',
    name: 'Cantón Antonio Ante',
    containedInPlace: {
      '@type': 'AdministrativeArea',
      name: 'Imbabura',
      containedInPlace: { '@type': 'Country', name: 'Ecuador' },
    },
  },
  ...(parroquia.coordenadas
    ? {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: parroquia.coordenadas.lat,
          longitude: parroquia.coordenadas.lng,
        },
      }
    : {}),
  ...(parroquia.poblacion
    ? {
        additionalProperty: {
          '@type': 'PropertyValue',
          name: 'Población',
          value: parroquia.poblacion,
        },
      }
    : {}),
});
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  image={ogSrc ?? undefined}
  canonical={`https://antonio-ante.gob.ec/parroquias/${parroquia.slug.current}`}
>
  <script slot="head" type="application/ld+json" set:html={jsonLd} />

  <!--
    Wrapper con --color definida en el ancestro común de AMBAS secciones.
    Así la propiedad cascada a hero Y contenido sin repetir el inline style.
  -->
  <div class="pp-root" style={`--color:${color};`}>
    <!-- ═══════════════════════════════════════════
         HERO — Minimalista compacto
         Fondo: gradiente del color de parroquia.
         Imagen: pegada al borde derecho, full-height,
                 fade izquierdo → un solo bloque visual.
    ═══════════════════════════════════════════ -->
    <section class="pp-hero" aria-label={`Parroquia ${parroquia.nombre}`}>
      {
        panelSrc && (
          <div class="pp-hero__panel" aria-hidden="true">
            <img
              src={panelSrc}
              srcset={panelSrcset ?? undefined}
              sizes="(max-width: 1024px) 40vw, 36vw"
              alt=""
              class="pp-hero__panel-img"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
            <div class="pp-hero__panel-fade" />
          </div>
        )
      }

      <div class="pp-hero__inner">
        <div class="pp-hero__text">
          <nav aria-label="Breadcrumb">
            <ol class="pp-breadcrumb" role="list">
              <li><a href="/">Inicio</a></li>
              <li aria-hidden="true">›</li>
              <li><a href="/parroquias">Parroquias</a></li>
              <li aria-hidden="true">›</li>
              <li aria-current="page">{parroquia.nombre}</li>
            </ol>
          </nav>

          <span class="pp-tipo">{tipoDisplay}</span>

          <div class="pp-hero__title-row">
            <span class="pp-hero__icon" aria-hidden="true">{mapIcon}</span>
            <h1 class="pp-hero__title">{parroquia.nombre}</h1>
          </div>

          {shortDesc && <p class="pp-hero__slogan">{shortDesc}</p>}

          <div class="pp-hero__stats" role="list" aria-label="Datos de la parroquia">
            {
              parroquia.poblacion && (
                <div class="pp-stat" role="listitem">
                  <strong>{parroquia.poblacion.toLocaleString('es-EC')}</strong>
                  <span>hab.</span>
                </div>
              )
            }
            {
              parroquia.superficieKm2 && (
                <div class="pp-stat" role="listitem">
                  <strong>{parroquia.superficieKm2}</strong>
                  <span>km²</span>
                </div>
              )
            }
            {
              altitude && (
                <div class="pp-stat" role="listitem">
                  <strong>{altitude}</strong>
                </div>
              )
            }
          </div>
        </div>
      </div>

      <div class="pp-hero__bar" aria-hidden="true"></div>
    </section>

    <!-- ═══════════════════════════════════════════
         IDENTIDAD — banda de color antes del contenido
    ═══════════════════════════════════════════ -->
    {
      shortDesc && (
        <div class="pp-identity">
          <div class="pp-identity__inner">
            <span class="pp-identity__icon" aria-hidden="true">
              {mapIcon}
            </span>
            <p class="pp-identity__quote">"{shortDesc}"</p>
          </div>
        </div>
      )
    }

    <!-- ═══════════════════════════════════════════
         CONTENIDO
    ═══════════════════════════════════════════ -->
    <div class="pp-content">
      <div class="pp-layout">
        <!-- ── Columna principal ── -->
        <main class="pp-main">
          <!-- Descripción -->
          {
            parroquia.descripcion && parroquia.descripcion.length > 0 ? (
              <div class="pp-block pp-reveal">
                <h2 class="pp-block__title">Acerca de {parroquia.nombre}</h2>
                <div class="pp-prose">
                  <PortableText blocks={parroquia.descripcion} />
                </div>
              </div>
            ) : staticData?.description ? (
              <div class="pp-block pp-reveal">
                <h2 class="pp-block__title">Acerca de {parroquia.nombre}</h2>
                <p class="pp-desc-text">{staticData.description}</p>
              </div>
            ) : (
              <div class="pp-block pp-block--empty pp-reveal">
                <p>Próximamente más información sobre {parroquia.nombre}.</p>
              </div>
            )
          }

          <!-- Actividades con emojis -->
          {
            activities.length > 0 && (
              <div class="pp-block pp-reveal">
                <h2 class="pp-block__title">¿Qué hacer aquí?</h2>
                <div class="pp-activities">
                  {activities.map((act) => (
                    <div class="pp-act">
                      <span class="pp-act__emoji" aria-hidden="true">
                        {activityEmojis[act] ?? '✦'}
                      </span>
                      {act}
                    </div>
                  ))}
                </div>
              </div>
            )
          }

          <!-- Galería de fotos -->
          {
            galleryThumbs.length > 0 && (
              <div class="pp-block pp-reveal">
                <h2 class="pp-block__title">📷 Galería</h2>
                <div class="pp-gallery-wrap">
                  <button class="pp-gnav pp-gnav--prev" aria-label="Fotos anteriores" hidden>
                    <svg
                      width="14"
                      height="14"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M15 19l-7-7 7-7"
                      />
                    </svg>
                  </button>
                  <div class="pp-gallery-strip" role="list">
                    {galleryThumbs.map((thumb, i) => (
                      <button
                        class="pp-gallery-thumb"
                        data-gallery-index={i}
                        role="listitem"
                        aria-label={`Ver foto ${i + 1}${galeriaFotos[i]?.alt ? ': ' + galeriaFotos[i].alt : ''}`}
                      >
                        <img src={thumb} alt="" loading="lazy" />
                      </button>
                    ))}
                  </div>
                  <button class="pp-gnav pp-gnav--next" aria-label="Más fotos">
                    <svg
                      width="14"
                      height="14"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  </button>
                </div>
              </div>
            )
          }

          <!-- Obras vinculadas (máx 3) -->
          {
            obras.length > 0 && (
              <div class="pp-block pp-reveal">
                <h2 class="pp-block__title">🏗️ Inversión pública</h2>
                <ul class="pp-obras">
                  {obras.map((obra) => {
                    const estadoLabel =
                      obra.estado === 'completada'
                        ? 'Completada'
                        : obra.estado === 'en_progreso'
                          ? 'En progreso'
                          : 'Planificada';
                    const estadoClass =
                      obra.estado === 'completada'
                        ? 'pp-obra__badge--ok'
                        : obra.estado === 'en_progreso'
                          ? 'pp-obra__badge--wip'
                          : 'pp-obra__badge--plan';
                    const thumbSrc = obra.imageUrl
                      ? cropUrl(obra.imageUrl, 160, 120, 0.5, 0.5)
                      : null;
                    return (
                      <li class="pp-obra">
                        {thumbSrc && (
                          <div class="pp-obra__thumb" aria-hidden="true">
                            <img src={thumbSrc} alt="" loading="lazy" />
                          </div>
                        )}
                        <div class="pp-obra__info">
                          <div class="pp-obra__meta">
                            <span class={`pp-obra__badge ${estadoClass}`}>{estadoLabel}</span>
                            {obra.porcentajeAvance > 0 && obra.estado !== 'completada' && (
                              <span class="pp-obra__pct">{obra.porcentajeAvance}%</span>
                            )}
                          </div>
                          <p class="pp-obra__titulo">{obra.titulo}</p>
                          <a href={`/obras/${obra.slug.current}`} class="pp-obra__link">
                            Ver detalle →
                          </a>
                        </div>
                      </li>
                    );
                  })}
                </ul>
                <a
                  href={`/obras?parroquia=${encodeURIComponent(parroquia.nombre)}`}
                  class="pp-obras__ver-todas"
                >
                  Ver todas las obras de {parroquia.nombre} →
                </a>
              </div>
            )
          }
        </main>

        <!-- ── Sidebar ── -->
        <aside class="pp-sidebar" aria-label="Información rápida">
          <!-- Stats visuales — sin tabla de formulario -->
          <div class="pp-stats pp-reveal">
            <span class="pp-stats__tipo">{tipoDisplay}</span>

            {
              parroquia.poblacion && (
                <div class="pp-stat-card">
                  <span class="pp-stat-card__icon" aria-hidden="true">
                    👥
                  </span>
                  <div>
                    <strong class="pp-stat-card__num">
                      {parroquia.poblacion.toLocaleString('es-EC')}
                    </strong>
                    <span class="pp-stat-card__label">habitantes</span>
                  </div>
                </div>
              )
            }
            {
              parroquia.superficieKm2 && (
                <div class="pp-stat-card">
                  <span class="pp-stat-card__icon" aria-hidden="true">
                    📐
                  </span>
                  <div>
                    <strong class="pp-stat-card__num">{parroquia.superficieKm2}</strong>
                    <span class="pp-stat-card__label">km² de superficie</span>
                  </div>
                </div>
              )
            }
            {
              altitude && (
                <div class="pp-stat-card">
                  <span class="pp-stat-card__icon" aria-hidden="true">
                    ⛰️
                  </span>
                  <div>
                    <strong class="pp-stat-card__num">{altitude}</strong>
                    <span class="pp-stat-card__label">altitud</span>
                  </div>
                </div>
              )
            }
            <div class="pp-stat-card">
              <span class="pp-stat-card__icon" aria-hidden="true">📍</span>
              <div>
                <strong class="pp-stat-card__num">Antonio Ante</strong>
                <span class="pp-stat-card__label">Imbabura, Ecuador</span>
              </div>
            </div>
          </div>

          <!-- Acciones rápidas: en mobile se agrupan en una tarjeta compacta -->
          <div class="pp-actions pp-reveal">
            {/* Google Maps */}
            {
              parroquia.coordenadas && (
                <a
                  href={`https://maps.google.com/?q=${parroquia.coordenadas.lat},${parroquia.coordenadas.lng}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="pp-action-btn pp-action-btn--map"
                  aria-label={`Ver ${parroquia.nombre} en Google Maps (abre en nueva pestaña)`}
                >
                  <span class="pp-action-btn__icon" aria-hidden="true">
                    <svg
                      width="17"
                      height="17"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                      />
                    </svg>
                  </span>
                  <span class="pp-action-btn__label">Ver en Google Maps</span>
                  <svg
                    class="pp-action-btn__chevron"
                    width="14"
                    height="14"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </a>
              )
            }

            {/* Explorar turismo */}
            <a href="/turismo" class="pp-action-btn pp-action-btn--turismo">
              <span class="pp-action-btn__icon" aria-hidden="true">🗺️</span>
              <span class="pp-action-btn__label">Explorar turismo</span>
              <svg
                class="pp-action-btn__chevron"
                width="14"
                height="14"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>

          <!-- Redes sociales -->
          {
            (parroquia.redesSociales ?? []).length > 0 && (
              <div class="pp-socials pp-reveal">
                <p class="pp-socials__title">Síguenos en redes</p>
                <div class="pp-socials__list">
                  {(parroquia.redesSociales ?? []).map(({ red, url }) => (
                    <a
                      href={url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class={`pp-social pp-social--${red}`}
                      aria-label={`${red.charAt(0).toUpperCase() + red.slice(1)} de ${parroquia.nombre} (abre en nueva pestaña)`}
                    >
                      {red === 'facebook' && (
                        <svg
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          width="16"
                          height="16"
                          aria-hidden="true"
                        >
                          <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z" />
                        </svg>
                      )}
                      {red === 'instagram' && (
                        <svg
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          width="16"
                          height="16"
                          aria-hidden="true"
                        >
                          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                        </svg>
                      )}
                      {red === 'twitter' && (
                        <svg
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          width="16"
                          height="16"
                          aria-hidden="true"
                        >
                          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                        </svg>
                      )}
                      {red === 'youtube' && (
                        <svg
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          width="16"
                          height="16"
                          aria-hidden="true"
                        >
                          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-2.7A12.94 12.94 0 0012 3.5a12.94 12.94 0 00-3.82.49 4.83 4.83 0 01-3.77 2.7A4.78 4.78 0 002 11.5v1a4.78 4.78 0 002.41 4.31 4.83 4.83 0 013.77 2.7 12.94 12.94 0 003.82.49 12.94 12.94 0 003.82-.49 4.83 4.83 0 013.77-2.7A4.78 4.78 0 0022 12.5v-1a4.78 4.78 0 00-2.41-4.31zM10 15.5v-5l5 2.5z" />
                        </svg>
                      )}
                      {red === 'tiktok' && (
                        <svg
                          viewBox="0 0 24 24"
                          fill="currentColor"
                          width="16"
                          height="16"
                          aria-hidden="true"
                        >
                          <path d="M19.59 6.69a4.83 4.83 0 01-3.77-2.7V3h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.97a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.19a8.11 8.11 0 004.74 1.51V6.25a4.85 4.85 0 01-.97-.56z" />
                        </svg>
                      )}
                      <span>
                        {red === 'twitter'
                          ? 'X (Twitter)'
                          : red.charAt(0).toUpperCase() + red.slice(1)}
                      </span>
                    </a>
                  ))}
                </div>
              </div>
            )
          }

          <!-- Volver -->
          <a href="/parroquias" class="pp-back">
            <svg
              width="15"
              height="15"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
