---
import BaseLayout from '@ui/BaseLayout.astro';
import Input from '@ui/Input.astro';
import Button from '@ui/Button.astro';

export const prerender = true;
---

<BaseLayout
  title="Contacto"
  description="Comunícate con el GAD Municipal del Cantón Antonio Ante. Escríbenos tus consultas, solicitudes y sugerencias."
>
  <!-- Hero -->
  <section class="bg-brand-primary text-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex items-center gap-2 text-white/60 text-sm" role="list">
          <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
          <li aria-hidden="true" class="select-none">›</li>
          <li class="text-white font-medium" aria-current="page">Contacto</li>
        </ol>
      </nav>
      <h1 class="text-3xl lg:text-4xl font-bold mb-3">Contáctanos</h1>
      <p class="text-white/80 max-w-xl">
        Escríbenos con tus consultas, solicitudes o sugerencias. Te responderemos en un plazo máximo
        de 3 días hábiles.
      </p>
    </div>
  </section>

  <section class="py-12 lg:py-16 bg-brand-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_360px] gap-12 items-start">
        <!-- Formulario -->
        <div>
          <!-- Estado de éxito (oculto por defecto) -->
          <div
            id="form-success"
            class="hidden bg-green-50 border border-green-200 rounded-xl p-6 mb-6"
            role="alert"
            aria-live="polite"
          >
            <div class="flex items-start gap-3">
              <svg
                class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <p class="font-bold text-green-800">Mensaje enviado con éxito</p>
                <p class="text-green-700 text-sm mt-1">
                  Tu mensaje fue recibido. Te responderemos en un plazo máximo de 3 días hábiles al
                  correo indicado.
                </p>
              </div>
            </div>
          </div>

          <!-- Estado de error genérico -->
          <div
            id="form-error"
            class="hidden bg-red-50 border border-red-200 rounded-xl p-6 mb-6"
            role="alert"
            aria-live="polite"
          >
            <div class="flex items-start gap-3">
              <svg
                class="w-6 h-6 text-red-600 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <p class="font-bold text-red-800">No fue posible enviar el mensaje</p>
                <p id="form-error-msg" class="text-red-700 text-sm mt-1">
                  Ocurrió un error inesperado. Por favor intenta de nuevo o contáctanos por
                  teléfono.
                </p>
              </div>
            </div>
          </div>

          <form
            id="contact-form"
            novalidate
            class="bg-white rounded-xl border border-gray-100 p-6 sm:p-8 space-y-5"
            aria-label="Formulario de contacto"
          >
            <!-- Honeypot oculto para bots -->
            <div class="sr-only" aria-hidden="true">
              <label for="website">No llenes este campo</label>
              <input id="website" name="_honeypot" type="text" tabindex="-1" autocomplete="off" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <Input
                id="nombre"
                label="Nombre completo"
                type="text"
                required
                autocomplete="name"
                placeholder="Ej. María García"
              />
              <Input
                id="email"
                label="Correo electrónico"
                type="email"
                required
                autocomplete="email"
                placeholder="ejemplo@correo.com"
              />
            </div>

            <Input
              id="telefono"
              label="Teléfono (opcional)"
              type="tel"
              autocomplete="tel"
              placeholder="+593 9 XXXX XXXX"
              hint="Incluye el código de país para llamadas internacionales."
            />

            <Input
              id="asunto"
              label="Asunto"
              type="text"
              required
              placeholder="¿Sobre qué trata tu mensaje?"
            />

            <div class="flex flex-col gap-1">
              <label for="mensaje" class="font-sans text-sm font-medium text-brand-dark">
                Mensaje
                <span aria-hidden="true" class="ml-0.5 text-red-600">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="5"
                required
                placeholder="Escribe tu consulta, solicitud o sugerencia aquí..."
                class="w-full rounded-md border border-neutral-300 px-3 py-2 font-sans text-base text-brand-dark bg-white placeholder:text-neutral-400 transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:border-brand-primary resize-y"
                aria-required="true"></textarea>
            </div>

            <p class="text-xs text-brand-dark/50">
              Al enviar este formulario aceptas que tu información sea tratada conforme a nuestra
              <a href="/transparencia" class="text-brand-primary underline hover:text-brand-primary"
                >política de transparencia</a
              >.
            </p>

            <Button type="submit" id="submit-btn"> Enviar mensaje </Button>
          </form>

          <noscript>
            <p
              class="mt-4 text-sm text-brand-dark/60 bg-yellow-50 border border-yellow-200 rounded-lg p-4"
            >
              El formulario requiere JavaScript. Si tienes JS deshabilitado, contáctanos
              directamente por teléfono o correo electrónico.
            </p>
          </noscript>
        </div>

        <!-- Información de contacto -->
        <aside aria-label="Información de contacto" class="lg:sticky lg:top-24 space-y-4">
          <div class="bg-white rounded-xl border border-gray-100 overflow-hidden">
            <div class="bg-brand-primary px-5 py-4">
              <h2 class="text-white font-bold text-sm uppercase tracking-wide">
                Información de contacto
              </h2>
            </div>
            <ul class="divide-y divide-gray-100" role="list">
              <li class="px-5 py-4 flex items-start gap-3 text-sm">
                <svg
                  class="w-4 h-4 text-brand-primary flex-shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p class="font-semibold text-brand-dark">Dirección</p>
                  <p class="text-brand-dark/60 mt-0.5">
                    Av. Luis Leoro Franco y Olmedo,<br />Atuntaqui, Imbabura, Ecuador
                  </p>
                </div>
              </li>
              <li class="px-5 py-4 flex items-start gap-3 text-sm">
                <svg
                  class="w-4 h-4 text-brand-primary flex-shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
                <div>
                  <p class="font-semibold text-brand-dark">Teléfono</p>
                  <a
                    href="tel:+59362908200"
                    class="text-brand-primary hover:text-brand-primary transition-colors mt-0.5 block"
                  >
                    +593 6 2908-200
                  </a>
                </div>
              </li>
              <li class="px-5 py-4 flex items-start gap-3 text-sm">
                <svg
                  class="w-4 h-4 text-brand-primary flex-shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <p class="font-semibold text-brand-dark">Correo electrónico</p>
                  <a
                    href="mailto:comunicacion@antonioante.gob.ec"
                    class="text-brand-primary hover:text-brand-primary transition-colors mt-0.5 break-all block"
                  >
                    comunicacion@antonioante.gob.ec
                  </a>
                </div>
              </li>
              <li class="px-5 py-4 flex items-start gap-3 text-sm">
                <svg
                  class="w-4 h-4 text-brand-primary flex-shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p class="font-semibold text-brand-dark">Horario de atención</p>
                  <p class="text-brand-dark/60 mt-0.5">Lun–Vie 08h00–17h00</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="bg-brand-accent rounded-xl p-5 border border-gray-100">
            <p class="text-xs text-brand-dark/60 leading-relaxed">
              Para solicitudes de información pública bajo la LOTAIP, visita la sección de
              <a
                href="/transparencia"
                class="text-brand-primary font-semibold hover:text-brand-primary">Transparencia</a
              >.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successBox = document.getElementById('form-success');
  const errorBox = document.getElementById('form-error');
  const errorMsg = document.getElementById('form-error-msg');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Reset states
      successBox?.classList.add('hidden');
      errorBox?.classList.add('hidden');

      const data = new FormData(form);
      const payload = {
        nombre: ((data.get('nombre') as string) ?? '').trim(),
        email: ((data.get('email') as string) ?? '').trim(),
        telefono: ((data.get('telefono') as string) ?? '').trim() || undefined,
        asunto: ((data.get('asunto') as string) ?? '').trim(),
        mensaje: ((data.get('mensaje') as string) ?? '').trim(),
        _honeypot: (data.get('_honeypot') as string) ?? '',
      };

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando...';
      }

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const json = (await res.json()) as { ok: boolean; message?: string };

        if (json.ok) {
          successBox?.classList.remove('hidden');
          successBox?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          form.reset();
        } else {
          if (errorMsg) errorMsg.textContent = json.message ?? 'Error al enviar el mensaje.';
          errorBox?.classList.remove('hidden');
          errorBox?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      } catch {
        if (errorMsg)
          errorMsg.textContent = 'Error de red. Verifica tu conexión e intenta de nuevo.';
        errorBox?.classList.remove('hidden');
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Enviar mensaje';
        }
      }
    });
  }
</script>
