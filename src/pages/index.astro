---
import BaseLayout from '@ui/BaseLayout.astro';
import CantonHero from '../modules/canton/ui/CantonHero.astro';
import ImpactCounters from '../modules/obras/ui/ImpactCounters.astro';
import ObrasGrid from '../modules/obras/ui/ObrasGrid.astro';
import ObraDestacada from '../modules/obras/ui/ObraDestacada.astro';
import { getObrasRecientes, getObraDestacada } from '@api/endpoints/obras';

const [obras, obraDestacada] = await Promise.all([
  getObrasRecientes(6).catch((err) => {
    console.error('[ObrasGrid]', err?.message ?? err);
    return [];
  }),
  getObraDestacada().catch((err) => {
    console.error('[ObraDestacada]', err?.message ?? err);
    return null;
  }),
]);
---

<BaseLayout
  title="Inicio"
  description="Portal oficial del Gobierno Autónomo Descentralizado Municipal del Cantón Antonio Ante, Imbabura, Ecuador. Conoce las obras, proyectos y gestión municipal."
>
  <!-- ─── Hero — Mapa interactivo + Panel de parroquias ────────────────────── -->
  <CantonHero />

  <!-- ─── Cifras de impacto (sección dark animada) ─────────────────────────── -->
  <div style="margin-top: 2.5rem;">
    <ImpactCounters />
  </div>

  <!-- ─── Obra destacada del período ─────────────────────────────────────── -->
  <ObraDestacada obra={obraDestacada} />

  <!-- ─── Obras en marcha ───────────────────────────────────────────────────── -->
  <ObrasGrid obras={obras} />

  <!-- ─── Identidad cantonal ──────────────────────────────────────────────── -->
  <section class="canton-callout" aria-labelledby="callout-heading">
    <div class="callout-bar" aria-hidden="true"></div>

    <div class="callout-inner">
      <div class="callout-text">
        <p class="callout-eyebrow">Cantón Antonio Ante · Imbabura · Ecuador</p>
        <h2 id="callout-heading" class="callout-title">
          Seis parroquias,<br />una sola identidad.
        </h2>
        <p class="callout-sub">Cada rincón guarda su propia historia, cultura y paisaje.</p>
      </div>

      <dl class="callout-metrics" aria-label="Estadísticas del cantón">
        {
          [
            { icono: '🏘️', num: '6', label: 'Parroquias', detail: '2 urbanas · 4 rurales' },
            { icono: '👥', num: '47.882', label: 'Habitantes', detail: 'Censo 2022 — INEC' },
            { icono: '🗺️', num: '79 km²', label: 'Superficie', detail: 'Cantón Antonio Ante' },
            { icono: '⛰️', num: '2.360 m', label: 'Altitud', detail: 'Sobre el nivel del mar' },
          ].map(({ icono, num, label, detail }) => (
            <div class="callout-metric">
              <span class="callout-metric-icon" aria-hidden="true">
                {icono}
              </span>
              <div>
                <strong class="callout-metric-num">{num}</strong>
                <span class="callout-metric-label">{label}</span>
                <span class="callout-metric-detail">{detail}</span>
              </div>
            </div>
          ))
        }
      </dl>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Canton callout ───────────────────────────────────────────────────────── */
  .canton-callout {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    overflow: hidden;
    max-width: 80rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    margin: 3rem max(1rem, calc((100% - 80rem) / 2)) 3.5rem;
  }

  .callout-bar {
    height: 4px;
    background: linear-gradient(90deg, #277816 0%, #d97706 55%, #dc2626 100%);
  }

  .callout-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem 2.5rem;
  }

  .callout-text {
    flex: 1;
    min-width: 0;
  }

  .callout-eyebrow {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #9ca3af;
    margin: 0 0 0.5rem;
  }

  .callout-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 800;
    color: #111827;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }

  .callout-sub {
    font-size: 0.82rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
    max-width: 32rem;
  }

  .callout-metrics {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
    margin: 0;
  }

  .callout-metric {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 0.75rem 1rem;
    min-width: 100px;
  }

  .callout-metric-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .callout-metric > div {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .callout-metric-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
    background: linear-gradient(135deg, #277816, #d97706);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    display: block;
  }

  .callout-metric-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6b7280;
    display: block;
  }

  .callout-metric-detail {
    font-size: 0.58rem;
    color: #9ca3af;
    display: block;
    margin-top: 0.1rem;
  }

  @media (max-width: 768px) {
    .canton-callout {
      margin-top: 0;
      border-radius: 0;
      border-left: none;
      border-right: none;
    }
    .callout-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
      padding: 1.5rem;
    }
    .callout-metrics {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.6rem;
    }
    .callout-metric {
      flex: none;
      min-width: 0;
      padding: 0.65rem 0.75rem;
      gap: 0.45rem;
    }
    .callout-metric-icon {
      font-size: 1.1rem;
    }
    .callout-metric-num {
      font-size: 0.95rem;
    }
    .callout-metric-detail {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .callout-inner {
      padding: 1.25rem;
      gap: 1rem;
    }
    .callout-title {
      font-size: 1.15rem;
    }
    .callout-sub {
      font-size: 0.78rem;
    }
    .callout-metrics {
      gap: 0.5rem;
    }
    .callout-metric {
      padding: 0.55rem 0.65rem;
    }
    .callout-metric-num {
      font-size: 0.88rem;
    }
    .callout-metric-label {
      font-size: 0.55rem;
    }
  }
</style>
