---
import BaseLayout from '@ui/BaseLayout.astro';

export const prerender = true;

const servicios = [
  {
    href: '/noticias',
    titulo: 'Noticias',
    descripcion: 'Mantente informado con las últimas novedades del cantón.',
    icono: 'newspaper',
  },
  {
    href: '/parroquias',
    titulo: 'Parroquias',
    descripcion: 'Conoce las seis parroquias del Cantón Antonio Ante.',
    icono: 'map',
  },
  {
    href: '/documentos',
    titulo: 'Documentos Oficiales',
    descripcion: 'Ordenanzas, resoluciones, presupuestos y planes de desarrollo.',
    icono: 'document',
  },
  {
    href: '/transparencia',
    titulo: 'Transparencia',
    descripcion: 'Rendición de cuentas y acceso a información pública.',
    icono: 'scale',
  },
  {
    href: '/contacto',
    titulo: 'Contáctanos',
    descripcion: 'Comunícate con el GAD Municipal de Antonio Ante.',
    icono: 'phone',
  },
  {
    href: '/turismo',
    titulo: 'Turismo',
    descripcion: 'Descubre la Capital de la Moda y sus atractivos.',
    icono: 'star',
  },
];
---

<BaseLayout
  title="Inicio"
  description="Portal oficial del Gobierno Autónomo Descentralizado Municipal del Cantón Antonio Ante, Imbabura, Ecuador. Noticias, servicios y trámites municipales."
>
  <!-- ─── Hero ──────────────────────────────────────────────────────────── -->
  <section
    class="relative bg-brand-primary text-white overflow-hidden"
    aria-labelledby="hero-heading"
  >
    <!-- Patrón de fondo decorativo -->
    <div class="absolute inset-0 opacity-5" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"></path>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"></rect>
      </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="max-w-3xl">
        <!-- Etiqueta superior -->
        <p
          class="inline-flex items-center gap-2 text-brand-secondary font-semibold text-sm uppercase tracking-wider mb-4"
        >
          <span aria-hidden="true">★</span>
          Capital de la Moda — Imbabura, Ecuador
        </p>

        <h1 id="hero-heading" class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight mb-6">
          Gobierno Autónomo Descentralizado Municipal del Cantón
          <span class="text-brand-secondary"> Antonio Ante</span>
        </h1>

        <p class="text-lg lg:text-xl leading-relaxed mb-10" style="color: rgba(255,255,255,0.85);">
          Trabajamos por el bienestar de las familias de Atuntaqui, Andrade Marín, Chaltura, Imbaya,
          Natabuela y San Roque. Encuentra noticias, documentos oficiales, información de nuestras
          parroquias y más.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="/noticias"
            class="inline-flex items-center gap-2 px-6 py-3 bg-brand-secondary text-white font-semibold rounded-md transition-opacity duration-150 hover:opacity-90 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-brand-primary outline-none"
          >
            Últimas noticias
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
              ></path>
            </svg>
          </a>
          <a
            href="/contacto"
            class="inline-flex items-center gap-2 px-6 py-3 font-semibold rounded-md border-2 border-white/60 text-white hover:border-white hover:bg-white/10 transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-brand-primary outline-none"
          >
            Contáctanos
          </a>
        </div>
      </div>
    </div>

    <!-- Curva de transición -->
    <div
      class="absolute bottom-0 left-0 right-0 h-8 bg-brand-light"
      style="clip-path: ellipse(55% 100% at 50% 100%);"
      aria-hidden="true"
    >
    </div>
  </section>

  <!-- ─── Servicios ─────────────────────────────────────────────────────── -->
  <section class="py-16 lg:py-24 bg-brand-light" aria-labelledby="servicios-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 id="servicios-heading" class="text-2xl lg:text-3xl font-bold text-brand-primary mb-3">
          Servicios municipales
        </h2>
        <p class="text-brand-dark max-w-xl mx-auto" style="opacity: 0.7;">
          Accede a la información y servicios del Cantón Antonio Ante.
        </p>
      </div>

      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" role="list">
        {
          servicios.map(({ href, titulo, descripcion, icono }) => (
            <li>
              <a
                href={href}
                class="group flex flex-col h-full bg-white rounded-xl p-6 transition-shadow duration-200 hover:shadow-lg focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 outline-none"
                style="box-shadow: var(--shadow-card);"
              >
                <div
                  class="w-12 h-12 rounded-lg bg-brand-primary flex items-center justify-center mb-4 transition-colors duration-200 group-hover:bg-brand-secondary"
                  aria-hidden="true"
                >
                  {icono === 'newspaper' && (
                    <svg
                      class="w-6 h-6 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-2-2h-2"
                      />
                    </svg>
                  )}
                  {icono === 'map' && (
                    <svg
                      class="w-6 h-6 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
                      />
                    </svg>
                  )}
                  {icono === 'document' && (
                    <svg
                      class="w-6 h-6 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                      />
                    </svg>
                  )}
                  {icono === 'scale' && (
                    <svg
                      class="w-6 h-6 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"
                      />
                    </svg>
                  )}
                  {icono === 'phone' && (
                    <svg
                      class="w-6 h-6 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                      />
                    </svg>
                  )}
                  {icono === 'star' && (
                    <svg
                      class="w-6 h-6 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                      />
                    </svg>
                  )}
                </div>

                <h3 class="text-base font-bold text-brand-primary mb-2 group-hover:text-brand-secondary transition-colors duration-200">
                  {titulo}
                </h3>
                <p class="text-sm text-brand-dark flex-1" style="opacity: 0.7;">
                  {descripcion}
                </p>

                <div class="mt-4 flex items-center gap-1 text-brand-primary text-sm font-medium group-hover:text-brand-secondary transition-colors duration-200">
                  <span>Ver más</span>
                  <svg
                    class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ─── Estadísticas del cantón ───────────────────────────────────────── -->
  <section
    class="py-16 bg-brand-accent border-t border-gray-100"
    aria-labelledby="estadisticas-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="estadisticas-heading" class="sr-only">Datos del Cantón Antonio Ante</h2>

      <ul class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center" role="list">
        {
          [
            { valor: '6', unidad: 'Parroquias', descripcion: '2 urbanas · 4 rurales' },
            { valor: '47.882', unidad: 'Habitantes', descripcion: 'Censo 2022 (INEC)' },
            { valor: '79 km²', unidad: 'Superficie', descripcion: 'Cantón Antonio Ante' },
            { valor: '2.360 m', unidad: 'Altitud', descripcion: 'Sobre el nivel del mar' },
          ].map(({ valor, unidad, descripcion }) => (
            <li>
              <p class="text-3xl lg:text-4xl font-bold text-brand-primary leading-none mb-1">
                {valor}
              </p>
              <p class="font-semibold text-brand-dark text-sm uppercase tracking-wide mb-1">
                {unidad}
              </p>
              <p class="text-xs text-brand-dark" style="opacity: 0.6;">
                {descripcion}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
