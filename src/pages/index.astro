---
import BaseLayout from '@ui/BaseLayout.astro';
import Card from '@ui/Card.astro';
import CategoryBadge from '@ui/CategoryBadge.astro';
import CantonHero from '../modules/canton/ui/CantonHero.astro';
import { getNoticiasDestacadas, getNoticiasRecientes } from '@api/endpoints/noticias';
import { getParroquias } from '@api/endpoints/parroquias';
import { getDocumentosVigentes } from '@api/endpoints/documentos';

export const prerender = true;

const [noticias, parroquias, documentos] = await Promise.all([
  getNoticiasDestacadas(3).catch(() => getNoticiasRecientes(3)),
  getParroquias(),
  getDocumentosVigentes(),
]);

const docsRecientes = documentos.slice(0, 3);

function formatDate(iso: string): string {
  return new Intl.DateTimeFormat('es-EC', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(new Date(iso));
}
---

<BaseLayout
  title="Inicio"
  description="Portal oficial del Gobierno Autónomo Descentralizado Municipal del Cantón Antonio Ante, Imbabura, Ecuador. Noticias, servicios y trámites municipales."
>
  <!-- ─── Hero — DISEÑO ANTIGUO integrado ────────────────────────────────── -->
  <CantonHero />

  <!-- ─── Noticias destacadas ───────────────────────────────────────────── -->
  {
    noticias.length > 0 && (
      <section class="py-16 lg:py-20 bg-brand-light" aria-labelledby="noticias-heading">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-end justify-between mb-10">
            <div>
              <p class="text-brand-secondary text-xs font-bold uppercase tracking-widest mb-1">
                Cantón Antonio Ante
              </p>
              <h2 id="noticias-heading" class="text-2xl lg:text-3xl font-bold text-brand-primary">
                Noticias destacadas
              </h2>
            </div>
            <a
              href="/noticias"
              class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-brand-primary hover:text-brand-secondary transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-brand-primary rounded"
            >
              Ver todas
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </div>

          <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" role="list">
            {noticias.map((noticia) => (
              <li>
                <Card
                  as="article"
                  href={`/noticias/${noticia.slug.current}`}
                  linkLabel={noticia.titulo}
                  interactive
                  padding="none"
                >
                  <div class="p-5 flex flex-col h-full">
                    <div class="flex items-center gap-2 mb-3">
                      <CategoryBadge categoria={noticia.categoria} />
                      <time
                        datetime={noticia.publishedAt}
                        class="text-xs text-brand-dark/50 font-medium"
                      >
                        {formatDate(noticia.publishedAt)}
                      </time>
                    </div>
                    <h3 class="text-base font-bold text-brand-primary leading-snug mb-2 line-clamp-2">
                      {noticia.titulo}
                    </h3>
                    <p class="text-sm text-brand-dark/70 leading-relaxed line-clamp-3 flex-1">
                      {noticia.resumen}
                    </p>
                    <p class="mt-4 text-xs font-semibold text-brand-primary flex items-center gap-1">
                      Leer más
                      <svg
                        class="w-3.5 h-3.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </p>
                  </div>
                </Card>
              </li>
            ))}
          </ul>

          <div class="sm:hidden mt-6 text-center">
            <a
              href="/noticias"
              class="text-sm font-semibold text-brand-primary hover:text-brand-secondary transition-colors"
            >
              Ver todas las noticias →
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- ─── Parroquias ────────────────────────────────────────────────────── -->
  {
    parroquias.length > 0 && (
      <section
        class="py-16 lg:py-20 bg-brand-accent border-t border-gray-100"
        aria-labelledby="parroquias-heading"
      >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-end justify-between mb-10">
            <div>
              <p class="text-brand-secondary text-xs font-bold uppercase tracking-widest mb-1">
                6 parroquias
              </p>
              <h2 id="parroquias-heading" class="text-2xl lg:text-3xl font-bold text-brand-primary">
                Conoce el cantón
              </h2>
            </div>
            <a
              href="/parroquias"
              class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-brand-primary hover:text-brand-secondary transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-brand-primary rounded"
            >
              Ver todas
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </div>

          <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4" role="list">
            {parroquias.map((p) => (
              <li>
                <a
                  href={`/parroquias/${p.slug.current}`}
                  class="group flex flex-col items-center text-center p-4 bg-white rounded-xl border border-gray-100 hover:border-brand-secondary hover:shadow-md transition-all duration-200 outline-none focus-visible:ring-2 focus-visible:ring-brand-primary"
                >
                  <div
                    class="w-12 h-12 rounded-full bg-brand-primary flex items-center justify-center mb-3 group-hover:bg-brand-secondary transition-colors duration-200"
                    aria-hidden="true"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                      />
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                      />
                    </svg>
                  </div>
                  <h3 class="text-sm font-bold text-brand-primary group-hover:text-brand-secondary transition-colors duration-200 leading-tight">
                    {p.nombre}
                  </h3>
                  {p.esCabeceraCantonal && (
                    <span class="mt-1 text-xs text-brand-secondary font-semibold">
                      Cabecera cantonal
                    </span>
                  )}
                  {p.poblacion && (
                    <span class="mt-1 text-xs text-brand-dark/50">
                      {p.poblacion.toLocaleString('es-EC')} hab.
                    </span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- ─── Documentos recientes ──────────────────────────────────────────── -->
  {
    docsRecientes.length > 0 && (
      <section class="py-16 lg:py-20 bg-brand-light" aria-labelledby="documentos-heading">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-end justify-between mb-10">
            <div>
              <p class="text-brand-secondary text-xs font-bold uppercase tracking-widest mb-1">
                Transparencia
              </p>
              <h2 id="documentos-heading" class="text-2xl lg:text-3xl font-bold text-brand-primary">
                Documentos oficiales
              </h2>
            </div>
            <a
              href="/documentos"
              class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-brand-primary hover:text-brand-secondary transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-brand-primary rounded"
            >
              Ver todos
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </a>
          </div>

          <ul class="flex flex-col gap-3" role="list">
            {docsRecientes.map((doc) => (
              <li>
                <a
                  href="/documentos"
                  class="group flex items-start gap-4 p-4 bg-white rounded-xl border border-gray-100 hover:border-brand-primary/30 hover:shadow-sm transition-all duration-200 outline-none focus-visible:ring-2 focus-visible:ring-brand-primary"
                >
                  <div
                    class="w-10 h-10 rounded-lg bg-brand-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-brand-primary/20 transition-colors duration-200"
                    aria-hidden="true"
                  >
                    <svg
                      class="w-5 h-5 text-brand-primary"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                      />
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                      <CategoryBadge categoria={doc.categoria} />
                      {doc.numero && (
                        <span class="text-xs text-brand-dark/50 font-mono">{doc.numero}</span>
                      )}
                    </div>
                    <p class="text-sm font-semibold text-brand-primary group-hover:text-brand-secondary transition-colors duration-200 leading-snug">
                      {doc.titulo}
                    </p>
                    <p class="text-xs text-brand-dark/50 mt-0.5">
                      {formatDate(doc.fechaPublicacion)}
                    </p>
                  </div>
                  <svg
                    class="w-4 h-4 text-brand-dark/30 group-hover:text-brand-primary flex-shrink-0 mt-0.5 transition-colors duration-200"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- ─── Estadísticas ──────────────────────────────────────────────────── -->
  <section class="py-16 bg-brand-primary text-white" aria-labelledby="stats-heading">
    <h2 id="stats-heading" class="sr-only">Datos del Cantón Antonio Ante</h2>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ul class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center" role="list">
        {
          [
            { valor: '6', unidad: 'Parroquias', detalle: '2 urbanas · 4 rurales' },
            { valor: '47.882', unidad: 'Habitantes', detalle: 'Censo 2022 — INEC' },
            { valor: '79 km²', unidad: 'Superficie', detalle: 'Cantón Antonio Ante' },
            { valor: '2.360 m', unidad: 'Altitud', detalle: 'Sobre el nivel del mar' },
          ].map(({ valor, unidad, detalle }) => (
            <li>
              <p class="text-3xl lg:text-4xl font-bold text-brand-secondary leading-none mb-1">
                {valor}
              </p>
              <p class="font-semibold text-white text-sm uppercase tracking-wide mb-0.5">
                {unidad}
              </p>
              <p class="text-xs text-white/60">{detalle}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
