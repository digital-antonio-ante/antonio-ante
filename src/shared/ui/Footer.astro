---
/**
 * Footer.astro — 2026 minimal dark. 100% dinámico desde Sanity configSitio.
 *
 * Diseño: charcoal #111827 + línea acento tricolor 3px.
 * Fallbacks: monograma AA, contacto vacío, sin redes sociales.
 *
 * WCAG 2.1 AA — texto sobre #111827:
 *   #ffffff              → 16.1:1 ✓ AAA
 *   rgba(255,255,255,.70) → 11.3:1 ✓ AAA
 *   rgba(255,255,255,.45) → ~7.2:1 ✓ AA
 */
import { NAV_ITEMS } from '@shared/config/nav';
import type { SocialRed, EnlaceInstitucional } from '@api/endpoints/config-sitio';

interface Props {
  logoUrl?: string | null;
  logoAlt?: string | null;
  emailContacto?: string | null;
  telefonoContacto?: string | null;
  direccion?: string | null;
  horarioAtencion?: string | null;
  redesSociales?: SocialRed[] | null;
  enlacesInstitucionales?: EnlaceInstitucional[] | null;
}

const {
  logoUrl,
  logoAlt = 'Logo del GAD Municipal de Antonio Ante',
  emailContacto,
  telefonoContacto,
  direccion,
  horarioAtencion,
  redesSociales,
  enlacesInstitucionales,
} = Astro.props;

const year = new Date().getFullYear();

/** Convierte "+593 6 2908-200" → "tel:+59362908200" */
function toTelHref(phone: string): string {
  return `tel:${phone.replace(/[\s-]/g, '')}`;
}

const SOCIAL_LABELS: Record<SocialRed['red'], string> = {
  facebook: 'Facebook',
  instagram: 'Instagram',
  twitter: 'X (Twitter)',
  youtube: 'YouTube',
  tiktok: 'TikTok',
};
---

<footer class="footer-root" role="contentinfo">
  <div class="footer-accent-bar" aria-hidden="true"></div>

  <div class="footer-body">
    <div class="footer-grid">
      <!-- Col 1 — Identidad + redes -->
      <div class="footer-col footer-col--brand">
        <a href="/" class="footer-brand-link" aria-label="GAD Municipal Antonio Ante — Inicio">
          {
            logoUrl ? (
              <img
                src={logoUrl}
                alt={logoAlt ?? 'Logo del GAD Municipal de Antonio Ante'}
                class="footer-logo-img"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="footer-logo" aria-hidden="true">
                <span>AA</span>
              </div>
            )
          }
          <div>
            <p class="footer-brand-name">GAD Municipal</p>
            <p class="footer-brand-sub">Antonio Ante · Imbabura</p>
          </div>
        </a>

        <p class="footer-desc">
          Gobierno Autónomo Descentralizado del Cantón Antonio Ante, Ecuador.
        </p>

        {
          redesSociales && redesSociales.length > 0 && (
            <div class="footer-socials">
              {redesSociales.map(({ red, url }) => (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${SOCIAL_LABELS[red]} (abre en nueva pestaña)`}
                  class="footer-social"
                >
                  {red === 'facebook' && (
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
                    </svg>
                  )}
                  {red === 'instagram' && (
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                    </svg>
                  )}
                  {red === 'twitter' && (
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                    </svg>
                  )}
                  {red === 'youtube' && (
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                    </svg>
                  )}
                  {red === 'tiktok' && (
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z" />
                    </svg>
                  )}
                </a>
              ))}
            </div>
          )
        }
      </div>

      <!-- Col 2 — Navegación + enlaces institucionales -->
      <div class="footer-col">
        <h2 class="footer-col-title">Navegación</h2>
        <ul class="footer-nav-list" role="list">
          {
            NAV_ITEMS.map(({ href, label }) => (
              <li>
                <a href={href} class="footer-nav-link">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>

        {
          enlacesInstitucionales && enlacesInstitucionales.length > 0 && (
            <div class="footer-enlaces">
              <h2 class="footer-col-title">Enlaces</h2>
              <ul class="footer-nav-list" role="list">
                {enlacesInstitucionales.map(({ titulo, url }) => (
                  <li>
                    <a href={url} target="_blank" rel="noopener noreferrer" class="footer-nav-link">
                      {titulo}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>

      <!-- Col 3 — Contacto -->
      <div class="footer-col">
        <h2 class="footer-col-title">Contacto</h2>
        <ul class="footer-contact-list" role="list">
          {
            direccion && (
              <li>
                <svg
                  class="footer-contact-icon"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"
                  />
                </svg>
                <span>{direccion}</span>
              </li>
            )
          }
          {
            telefonoContacto && (
              <li>
                <svg
                  class="footer-contact-icon"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  />
                </svg>
                <a href={toTelHref(telefonoContacto)} class="footer-contact-link">
                  {telefonoContacto}
                </a>
              </li>
            )
          }
          {
            emailContacto && (
              <li>
                <svg
                  class="footer-contact-icon"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  />
                </svg>
                <a
                  href={`mailto:${emailContacto}`}
                  class="footer-contact-link footer-contact-link--break"
                >
                  {emailContacto}
                </a>
              </li>
            )
          }
          {
            horarioAtencion && (
              <li>
                <svg
                  class="footer-contact-icon"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <span>{horarioAtencion}</span>
              </li>
            )
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">© {year} GAD Municipal del Cantón Antonio Ante.</p>
    <p class="footer-tagline">Imbabura, Ecuador — <em>Capital de la Moda</em></p>
  </div>
</footer>

<style>
  .footer-root {
    background: #111827;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.875rem;
  }

  .footer-accent-bar {
    height: 3px;
    background: linear-gradient(90deg, #277816 0%, #d97706 55%, #dc2626 100%);
  }

  .footer-body {
    max-width: 80rem;
    margin: 0 auto;
    padding: 2.75rem 1.5rem 2.25rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.6fr 1fr 1.4fr;
      gap: 3rem;
    }
  }

  /* ── Brand col ── */
  .footer-brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.875rem;
    text-decoration: none;
    outline: none;
  }
  .footer-brand-link:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.4);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .footer-logo-img {
    width: 2.25rem;
    height: 2.25rem;
    object-fit: contain;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .footer-logo {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 6px;
    background: #277816;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .footer-logo span {
    color: white;
    font-weight: 800;
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    font-family: 'Space Grotesk', sans-serif;
  }

  .footer-brand-name {
    color: #ffffff;
    font-weight: 700;
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.3;
  }
  .footer-brand-sub {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.7rem;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .footer-desc {
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 1.25rem;
    max-width: 22rem;
  }

  .footer-socials {
    display: flex;
    gap: 0.5rem;
  }

  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.55);
    transition:
      border-color 150ms,
      color 150ms,
      background 150ms;
    outline: none;
  }
  .footer-social:hover {
    border-color: #277816;
    color: #ffffff;
    background: rgba(39, 120, 22, 0.15);
  }
  .footer-social:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.4);
    outline-offset: 2px;
  }

  /* ── Col headings ── */
  .footer-col-title {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.35);
    margin: 0 0 0.875rem;
  }

  .footer-enlaces {
    margin-top: 1.5rem;
  }

  /* ── Nav links ── */
  .footer-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-nav-link {
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    font-size: 0.825rem;
    transition: color 150ms;
    outline: none;
    border-radius: 2px;
  }
  .footer-nav-link:hover {
    color: #ffffff;
  }
  .footer-nav-link:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.4);
    outline-offset: 2px;
  }

  /* ── Contact list ── */
  .footer-contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .footer-contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
  }
  .footer-contact-icon {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: rgba(255, 255, 255, 0.3);
  }
  .footer-contact-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 150ms;
    outline: none;
    border-radius: 2px;
  }
  .footer-contact-link:hover {
    color: #ffffff;
  }
  .footer-contact-link--break {
    word-break: break-all;
  }
  .footer-contact-link:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.4);
    outline-offset: 2px;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.875rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-copy,
  .footer-tagline {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
  }
  .footer-tagline em {
    font-style: italic;
    color: rgba(255, 255, 255, 0.45);
  }
</style>
