---
/**
 * Footer.astro — Pie de página institucional del portal GAD Antonio Ante.
 *
 * WCAG 2.1 AA:
 * - role="contentinfo" implícito en <footer>
 * - aria-label descriptivos en enlaces de redes sociales
 * - Contraste mínimo 4.5:1 en texto sobre fondo oscuro (#003366):
 *     Blanco puro (#fff) sobre #003366: 12.6:1 ✓
 *     #c5a059 (secondary) sobre #003366: 4.7:1 ✓
 *
 * Trade-off: contact info hardcoded mientras el Studio no esté deployado.
 * TODO: reemplazar con fetch a configSitio de Sanity (Fase 3).
 */
import { NAV_ITEMS } from '@shared/config/nav';

const year = new Date().getFullYear();
---

<footer class="bg-brand-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <!-- Grid principal -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
      <!-- Bloque 1: Identidad y redes sociales -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div
            class="w-10 h-10 bg-brand-secondary rounded flex items-center justify-center flex-shrink-0"
            aria-hidden="true"
          >
            <span class="text-white font-bold text-sm select-none">AA</span>
          </div>
          <div class="leading-tight">
            <p class="font-bold text-base">GAD Municipal</p>
            <p class="text-brand-secondary font-semibold text-sm">Antonio Ante</p>
          </div>
        </div>

        <p class="text-sm leading-relaxed mb-6 text-white/80">
          Gobierno Autónomo Descentralizado Municipal del Cantón Antonio Ante, Imbabura, Ecuador.
        </p>

        <!-- Redes sociales -->
        <div class="flex gap-3">
          <a
            href="https://www.facebook.com/GADAntonioAnte"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GAD Antonio Ante en Facebook (abre en nueva pestaña)"
            class="footer-social-link"
          >
            <svg
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
              ></path>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/gadantonioante"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GAD Antonio Ante en Instagram (abre en nueva pestaña)"
            class="footer-social-link"
          >
            <svg
              class="w-5 h-5"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Bloque 2: Navegación -->
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-brand-secondary mb-4">
          Navegación
        </h2>
        <ul class="space-y-2" role="list">
          {
            NAV_ITEMS.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-white/80 hover:text-brand-secondary transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary rounded"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Bloque 3: Información de contacto -->
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-brand-secondary mb-4">
          Contacto
        </h2>
        <ul class="space-y-3 text-sm text-white/80" role="list">
          <!-- Dirección -->
          <li class="flex items-start gap-2">
            <svg
              class="w-4 h-4 mt-0.5 text-brand-secondary flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>
              Av. Luis Leoro Franco y Olmedo,<br />
              Atuntaqui, Imbabura, Ecuador
            </span>
          </li>

          <!-- Teléfono -->
          <li class="flex items-center gap-2">
            <svg
              class="w-4 h-4 text-brand-secondary flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <a
              href="tel:+59362908200"
              class="hover:text-brand-secondary transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary rounded"
            >
              +593 6 2908-200
            </a>
          </li>

          <!-- Email -->
          <li class="flex items-center gap-2">
            <svg
              class="w-4 h-4 text-brand-secondary flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <a
              href="mailto:comunicacion@antonioante.gob.ec"
              class="break-all hover:text-brand-secondary transition-colors duration-150 outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary rounded"
            >
              comunicacion@antonioante.gob.ec
            </a>
          </li>

          <!-- Horario -->
          <li class="flex items-center gap-2">
            <svg
              class="w-4 h-4 text-brand-secondary flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
              focusable="false"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>Lun–Vie 08h00–17h00</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Línea divisoria y copyright -->
    <div
      class="mt-12 pt-6 border-t border-white/20 flex flex-col sm:flex-row justify-between items-center gap-4"
    >
      <p class="text-xs text-white/60 text-center sm:text-left">
        © {year} GAD Municipal del Cantón Antonio Ante. Todos los derechos reservados.
      </p>
      <p class="text-xs text-white/60 text-center sm:text-right">
        Imbabura, Ecuador &mdash;
        <span class="text-brand-secondary font-medium">Capital de la Moda</span>
      </p>
    </div>
  </div>
</footer>

<style>
  /* Botón de red social: bg-white/10 → hover:bg-brand-secondary
   * Usamos <style> porque Tailwind no puede purgar clases en variables CSS
   * arbitrarias con opacity dentro de hover states complejos en este contexto. */
  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.375rem;
    background-color: rgb(255 255 255 / 0.1);
    color: white;
    transition: background-color 150ms ease;
    outline: none;
  }
  .footer-social-link:hover {
    background-color: var(--color-brand-secondary);
  }
  .footer-social-link:focus-visible {
    ring: 2px solid var(--color-brand-secondary);
    outline: 2px solid var(--color-brand-secondary);
    outline-offset: 2px;
  }
</style>
