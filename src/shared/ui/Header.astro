---
/**
 * Header.astro — Cabecera institucional del portal GAD Antonio Ante.
 *
 * WCAG 2.1 AA:
 * - aria-current="page" en ítem activo
 * - aria-expanded + aria-controls en el botón hamburguesa
 * - Escape cierra el menú y devuelve el foco al botón
 * - Contraste mínimo 7.1:1 en todos los estados de texto
 */
import { NAV_ITEMS } from '@shared/config/nav';

interface Props {
  logoUrl?: string | null;
  logoAlt?: string | null;
}

const { logoUrl, logoAlt = 'Logo del GAD Municipal de Antonio Ante' } = Astro.props;
const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-40 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Identidad institucional -->
      <a
        href="/"
        class="flex items-center gap-3 flex-shrink-0"
        aria-label="GAD Municipal de Antonio Ante — Inicio"
      >
        {
          logoUrl ? (
            <img
              src={logoUrl}
              alt={logoAlt ?? 'Logo del GAD Municipal de Antonio Ante'}
              class="w-10 h-10 lg:w-12 lg:h-12 object-contain flex-shrink-0 rounded-xl"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div
              class="w-10 h-10 lg:w-12 lg:h-12 bg-brand-primary rounded flex items-center justify-center flex-shrink-0"
              aria-hidden="true"
            >
              <span class="text-white font-bold text-sm lg:text-base leading-none select-none">
                AA
              </span>
            </div>
          )
        }
        <div class="flex flex-col leading-tight">
          <span class="text-brand-primary font-bold text-sm lg:text-base">GAD Municipal</span>
          <span class="text-brand-primary font-semibold text-xs lg:text-sm">Antonio Ante</span>
        </div>
      </a>

      <!-- Navegación desktop -->
      <nav aria-label="Navegación principal" class="hidden lg:block">
        <ul class="flex items-center gap-1" role="list">
          {
            NAV_ITEMS.map(({ href, label }) => {
              const active = isActive(href);
              return (
                <li>
                  <a
                    href={href}
                    aria-current={active ? 'page' : undefined}
                    class:list={[
                      'px-4 py-2 text-sm font-medium rounded-md transition-colors duration-150 outline-none',
                      'focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2',
                      active
                        ? 'text-brand-primary bg-brand-accent border-b-2 border-brand-primary'
                        : 'text-brand-ink hover:text-brand-primary hover:bg-brand-accent',
                    ]}
                  >
                    {label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>

      <!-- Botón hamburguesa (solo móvil) -->
      <button
        id="menu-toggle"
        type="button"
        class="lg:hidden flex items-center justify-center w-10 h-10 rounded-md text-brand-primary hover:bg-brand-accent transition-colors focus-visible:ring-2 focus-visible:ring-brand-primary focus-visible:ring-offset-2 outline-none"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú de navegación"
      >
        <svg
          id="icon-hamburger"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
          focusable="false"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="icon-close"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
          focusable="false"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menú móvil -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-gray-200 bg-white"
    aria-hidden="true"
  >
    <nav aria-label="Navegación móvil">
      <ul class="px-4 py-3 space-y-1" role="list">
        {
          NAV_ITEMS.map(({ href, label }) => {
            const active = isActive(href);
            return (
              <li>
                <a
                  href={href}
                  aria-current={active ? 'page' : undefined}
                  class:list={[
                    'flex items-center px-4 py-3 text-base font-medium rounded-md transition-colors duration-150',
                    active
                      ? 'text-brand-primary bg-brand-accent border-l-4 border-brand-primary'
                      : 'text-brand-ink hover:text-brand-primary hover:bg-brand-accent',
                  ]}
                >
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>

<!-- Static file served from 'self' — satisfies CSP without 'unsafe-inline' -->
<script src="/js/header.js" defer></script>
