---
import SEOHead from './SEOHead.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import '@styles/global.css';
import { getConfigSitio } from '@api/endpoints/config-sitio';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  publishedAt?: string;
  noindex?: boolean;
}

const props = Astro.props;
const config = await getConfigSitio().catch(() => null);

// La imagen OG: prioridad → prop explícita → Sanity ogImageDefault → fallback local
const ogImage = props.image ?? config?.ogImageUrl ?? undefined;

// GA4 se inyecta solo en producción (import.meta.env.PROD = true en build)
const ga4 = import.meta.env.PROD
  ? `<script async src="https://www.googletagmanager.com/gtag/js?id=G-JER9NBHCGP"></script>` +
    `<script>window.dataLayer=window.dataLayer||[];` +
    `function gtag(){dataLayer.push(arguments);}` +
    `gtag('js',new Date());gtag('config','G-JER9NBHCGP');</script>`
  : '';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#277816" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <!-- Preconnect a Google Fonts: establece conexión antes de que la CSS la pida -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700;800&display=swap"
    />
    <SEOHead {...props} image={ogImage} />
    <slot name="head" />

    <!-- Google Analytics 4 — solo en producción -->
    <Fragment set:html={ga4} />
  </head>
  <body
    class="min-h-screen text-brand-dark font-sans flex flex-col"
    style="background: linear-gradient(180deg, #f6fdf8 0%, #fafffe 18%, #fdfefe 50%, #fffdf9 100%); background-attachment: fixed;"
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-brand-primary focus:text-white focus:rounded-md"
    >
      Saltar al contenido principal
    </a>

    <Header logoUrl={config?.logoUrl} logoAlt={config?.logoAlt} />

    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>

    <Footer
      logoUrl={config?.logoUrl}
      logoAlt={config?.logoAlt}
      emailContacto={config?.emailContacto}
      telefonoContacto={config?.telefonoContacto}
      direccion={config?.direccion}
      horarioAtencion={config?.horarioAtencion}
      redesSociales={config?.redesSociales}
      enlacesInstitucionales={config?.enlacesInstitucionales}
    />
  </body>
</html>
