---
/**
 * SEOHead — meta tags completos para Open Graph, Twitter Cards y SEO.
 * Incluir en el <head> de cada layout. Diseñado para pasar validate-seo.ts.
 *
 * Uso:
 *   <SEOHead
 *     title="Noticias"
 *     description="Últimas noticias del GAD Antonio Ante"
 *     image="/og-default.jpg"
 *   />
 */

interface Props {
  title: string;
  description: string;
  /** URL absoluta o path relativo de la imagen OG (1200x630 recomendado) */
  image?: string;
  /** Tipo Open Graph. Default: "website" */
  type?: 'website' | 'article';
  /** Anula la URL canónica si es diferente de la ruta actual */
  canonical?: string;
  /** Fecha de publicación (ISO 8601) para articles */
  publishedAt?: string;
  /** Evita indexación en esta página específica */
  noindex?: boolean;
}

const {
  title: pageTitle,
  description,
  image,
  type = 'website',
  canonical,
  publishedAt,
  noindex = false,
} = Astro.props;

const siteName = 'GAD Municipal de Antonio Ante';
const fullTitle = `${pageTitle} | ${siteName}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://antonio-ante.gob.ec';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image
  ? image.startsWith('http')
    ? image
    : `${siteUrl}${image}`
  : `${siteUrl}/og-default.jpg`;
---

{/* ─── Core SEO ─────────────────────────────────────────────────────────── */}
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

{/* ─── Open Graph ───────────────────────────────────────────────────────── */}
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content="es_EC" />
{publishedAt && <meta property="article:published_time" content={publishedAt} />}

{/* ─── Twitter Card ─────────────────────────────────────────────────────── */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
