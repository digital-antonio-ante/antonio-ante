---
/**
 * ParishCardStrip.astro — Tira horizontal de tarjetas por parroquia.
 *
 * Fondo: foto real (object-fit: cover) con fallback al color de parroquia.
 * Color-wash con mix-blend-mode: multiply en hover — presencia del diseño original.
 * Interacción vía data-select-parish (CSP-safe, sin onclick inline).
 * Desktop: grid 6 columnas. Tablet/móvil: scroll horizontal con snap.
 */
import type { ParishData } from '../data/parishes';

interface Props {
  parishes: Record<string, ParishData>;
}

const { parishes } = Astro.props;
const parishList = Object.values(parishes);
---

<section class="parish-strip-section" aria-label="Parroquias del Cantón Antonio Ante">
  <div class="strip-header">
    <div class="strip-header-left">
      <p class="strip-eyebrow">Cantón Antonio Ante</p>
      <h2 class="strip-title">Conoce cada parroquia</h2>
    </div>
    <p class="strip-hint" aria-hidden="true">
      <span class="strip-hint-arrow">←→</span> Desliza para explorar
    </p>
  </div>

  <div class="strip-track-wrapper">
    <div class="strip-track" role="list">
      {
        parishList.map((p) => (
          <button
            class="pcard"
            data-select-parish={p.id}
            style={`--parish-color: ${p.color};`}
            role="listitem"
            aria-label={`Ver información de ${p.name} — ${p.type} — ${p.shortDesc}`}
          >
            {/* Foto de fondo con fallback al color de parroquia */}
            {p.imageSrc ? (
              <img
                src={p.imageSrc}
                alt=""
                class="pcard-img"
                loading="lazy"
                aria-hidden="true"
                style={`object-position: ${p.imageObjectPosition ?? 'center'};`}
              />
            ) : (
              <div class="pcard-img-fallback" aria-hidden="true" />
            )}

            {/* Gradiente oscuro base — siempre visible, da legibilidad al texto */}
            <div class="pcard-gradient" aria-hidden="true" />

            {/* Color-wash en hover: mix-blend-mode multiply sobre la foto */}
            <div class="pcard-color-wash" aria-hidden="true" />

            {/* Cuerpo de texto */}
            <div class="pcard-body">
              <div class="pcard-top">
                <span class="pcard-icon" aria-hidden="true">
                  {p.mapIcon}
                </span>
                <span class="pcard-type">{p.type}</span>
              </div>
              <h3 class="pcard-name">{p.name}</h3>
              <p class="pcard-desc">{p.shortDesc}</p>
              <div class="pcard-cta" aria-hidden="true">
                <span>Ver parroquia</span>
                <span class="pcard-arrow">→</span>
              </div>
            </div>

            {/* Barra de acento inferior */}
            <div class="pcard-accent-bar" aria-hidden="true" />
          </button>
        ))
      }
    </div>

    <div class="strip-fade strip-fade--left" aria-hidden="true"></div>
    <div class="strip-fade strip-fade--right" aria-hidden="true"></div>
  </div>
</section>

<style>
  /* ── Sección ── */
  .parish-strip-section {
    width: 100%;
  }

  .strip-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding: 0 0.25rem;
  }
  .strip-header-left {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .strip-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    margin: 0;
  }
  .strip-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-main);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0;
  }
  .strip-hint {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding-bottom: 0.15rem;
    margin: 0;
  }
  .strip-hint-arrow {
    font-size: 0.9rem;
    letter-spacing: -0.05em;
  }

  /* ── Track con scroll ── */
  .strip-track-wrapper {
    position: relative;
  }
  .strip-track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
  }
  .strip-track::-webkit-scrollbar {
    display: none;
  }

  /* Fades laterales — adaptan al color del hero */
  .strip-fade {
    position: absolute;
    top: 0;
    bottom: 0.5rem;
    width: 60px;
    pointer-events: none;
    z-index: 2;
  }
  .strip-fade--left {
    left: 0;
    background: linear-gradient(to right, var(--bg-body, #f6fdf8), transparent);
  }
  .strip-fade--right {
    right: 0;
    background: linear-gradient(to left, var(--bg-body, #f6fdf8), transparent);
  }

  /* ── Card ── */
  .pcard {
    flex: 0 0 220px;
    height: 320px;
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    cursor: pointer;
    scroll-snap-align: start;
    border: none;
    padding: 0;
    background: #0f172a;
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.14);
  }
  .pcard:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.22),
      0 0 0 2px var(--parish-color);
  }
  .pcard.active {
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.28),
      0 0 0 3px var(--parish-color);
  }
  .pcard:focus-visible {
    outline: 3px solid var(--parish-color);
    outline-offset: 2px;
  }

  /* Foto de fondo */
  .pcard-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .pcard:hover .pcard-img {
    transform: scale(1.08);
  }

  /* Fallback cuando no hay foto — gradiente del color de parroquia */
  .pcard-img-fallback {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--parish-color) 70%, #000),
      var(--parish-color)
    );
  }

  /* Gradiente oscuro base — siempre visible */
  .pcard-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(5, 10, 20, 0.95) 0%,
      rgba(5, 10, 20, 0.55) 45%,
      rgba(5, 10, 20, 0.1) 100%
    );
    z-index: 1;
  }

  /* Color-wash en hover — tiñe la foto con el color de la parroquia */
  .pcard-color-wash {
    position: absolute;
    inset: 0;
    background: var(--parish-color);
    opacity: 0;
    mix-blend-mode: multiply;
    transition: opacity 0.4s ease;
    z-index: 1;
  }
  .pcard:hover .pcard-color-wash {
    opacity: 0.28;
  }
  .pcard.active .pcard-color-wash {
    opacity: 0.18;
  }

  /* Cuerpo de texto */
  .pcard-body {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.1rem;
    gap: 0.3rem;
    text-align: left;
  }
  .pcard-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.2rem;
  }
  .pcard-icon {
    font-size: 1.4rem;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
  }
  .pcard-type {
    font-size: 0.58rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: white;
    background: var(--parish-color);
    padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    opacity: 0.95;
  }
  .pcard-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0;
  }
  .pcard-desc {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.45;
    max-height: 0;
    overflow: hidden;
    transition:
      max-height 0.4s ease,
      opacity 0.3s ease;
    opacity: 0;
    margin: 0;
  }
  .pcard:hover .pcard-desc {
    max-height: 3rem;
    opacity: 1;
  }
  .pcard-cta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--parish-color);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity 0.3s ease 0.05s,
      transform 0.3s ease 0.05s;
  }
  .pcard:hover .pcard-cta,
  .pcard.active .pcard-cta {
    opacity: 1;
    transform: translateY(0);
  }
  .pcard-arrow {
    transition: transform 0.25s ease;
  }
  .pcard:hover .pcard-arrow {
    transform: translateX(3px);
  }

  /* Barra de acento inferior */
  .pcard-accent-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--parish-color);
    z-index: 3;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .pcard:hover .pcard-accent-bar,
  .pcard.active .pcard-accent-bar {
    transform: scaleX(1);
  }

  /* ── Responsive ── */
  @media (min-width: 1100px) {
    .strip-track {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      overflow-x: visible;
      scroll-snap-type: none;
    }
    .strip-fade {
      display: none;
    }
    .pcard {
      flex: none;
      width: auto;
      height: 300px;
    }
    .strip-hint {
      display: none;
    }
  }
  @media (max-width: 768px) {
    .strip-title {
      font-size: 1.3rem;
    }
    .pcard {
      flex: 0 0 180px;
      height: 280px;
    }
  }
  @media (max-width: 480px) {
    .pcard {
      flex: 0 0 160px;
      height: 260px;
    }
    .strip-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pcard,
    .pcard-img,
    .pcard-color-wash,
    .pcard-desc,
    .pcard-cta,
    .pcard-accent-bar {
      transition: none;
    }
  }
</style>
