---
/**
 * CantonMapSVG.astro — Mapa interactivo del Cantón Antonio Ante.
 *
 * Visual layer : franja_g-dos.svg — diseño ilustrado, incrustado vía <image>
 *                (mismo viewBox 1694×2528, sin recálculo de coordenadas).
 * Interaction layer: polígonos transparentes extraídos del mismo SVG que
 *                capturan hover/focus/click y activan el InfoPanel.
 *
 * El JS en canton-hero.ts detecta data-select-parish — sin cambios.
 */
import { PARISHES, PARISH_POLYGONS } from '../data/parishes';
---

<div class="map-root" aria-label="Mapa interactivo del Cantón Antonio Ante">
  <svg
    class="canton-svg"
    viewBox="0 0 1694 2528"
    preserveAspectRatio="xMidYMid meet"
    xmlns="http://www.w3.org/2000/svg"
    xmlns:xlink="http://www.w3.org/1999/xlink"
    role="img"
    aria-label="Mapa del Cantón Antonio Ante con sus seis parroquias"
  >
    <defs>
      <!-- Glow de color por parroquia para el estado activo -->
      {
        PARISH_POLYGONS.map(({ id }) => {
          const p = PARISHES[id];
          return (
            <filter id={`glow-${id}`} x="-30%" y="-30%" width="160%" height="160%">
              <feGaussianBlur stdDeviation="22" result="blur" />
              <feFlood flood-color={p.color} flood-opacity="0.65" result="color" />
              <feComposite in="color" in2="blur" operator="in" result="colored-blur" />
              <feMerge>
                <feMergeNode in="colored-blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
          );
        })
      }
    </defs>

    <!-- Fondo transparente: la ilustración flota sobre el fondo de la página -->

    <!-- ── Arte ilustrado (franja_g-dos.svg) — mismo viewBox → sin transformación -->
    <image
      href="/images/franja_g-dos.svg"
      x="0"
      y="0"
      width="1694"
      height="2528"
      preserveAspectRatio="xMidYMid meet"
    />

    <!-- ── Capa de interacción: polígonos extraídos del mismo arte -->
    {
      PARISH_POLYGONS.map(({ id, points }) => {
        const p = PARISHES[id];
        return (
          <g
            class="parish-zone"
            data-select-parish={id}
            style={`--pc: ${p.color};`}
            role="button"
            tabindex="0"
            aria-label={`Seleccionar parroquia ${p.name}`}
          >
            {/* Overlay semitransparente — absorbe pointer events */}
            <polygon class="parish-overlay" points={points} />
            {/* Borde de resaltado */}
            <polygon class="parish-stroke" points={points} fill="none" />
          </g>
        );
      })
    }

    <!-- ── Indicador norte -->
    <g transform="translate(80, 2420)" aria-hidden="true">
      <circle
        cx="0"
        cy="0"
        r="42"
        fill="white"
        fill-opacity="0.88"
        stroke="rgba(26,95,122,0.25)"
        stroke-width="2"></circle>
      <text x="0" y="-10" text-anchor="middle" font-size="34" font-weight="900" fill="#1a5f7a"
        >N</text
      >
      <polygon points="0,-5 -5,12 0,8 5,12" fill="#DC2626"></polygon>
    </g>

    <!-- ── Escala gráfica -->
    <g transform="translate(1520, 2460)" aria-hidden="true">
      <rect x="-80" y="-5" width="80" height="5" fill="#1a5f7a" fill-opacity="0.45"></rect>
      <rect x="0" y="-5" width="80" height="5" fill="#1a5f7a" fill-opacity="0.2"></rect>
      <text x="-80" y="-14" text-anchor="start" font-size="22" fill="rgba(100,116,139,0.75)">0</text
      >
      <text x="80" y="-14" text-anchor="end" font-size="22" fill="rgba(100,116,139,0.75)">5 km</text
      >
    </g>
  </svg>
</div>

<style>
  /* ── Contenedor ─────────────────────────────────────────────────────────── */
  .map-root {
    position: relative;
    width: 100%;
    max-width: 520px;
    margin: 0 auto 0 0;
    user-select: none;
  }

  .canton-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Capa de interacción ────────────────────────────────────────────────── */

  /* Suprimir el rectángulo de foco nativo del navegador sobre <g tabindex> */
  .parish-zone {
    outline: none;
  }

  /* Overlay: recibe todos los pointer events; fill invisible por defecto */
  .parish-overlay {
    fill: transparent;
    cursor: pointer;
    transition: fill 0.2s ease;
  }

  /* Borde de parroquia: invisible por defecto */
  .parish-stroke {
    stroke: white;
    stroke-width: 0;
    stroke-linejoin: round;
    opacity: 0;
    pointer-events: none;
    transition:
      stroke-width 0.22s ease,
      opacity 0.22s ease;
  }

  /* ── Hover / Focus ── */
  .parish-zone:hover .parish-overlay,
  .parish-zone:focus-visible .parish-overlay {
    fill: rgba(255, 255, 255, 0.18);
  }
  .parish-zone:hover .parish-stroke,
  .parish-zone:focus-visible .parish-stroke {
    stroke-width: 12;
    opacity: 0.85;
  }

  /* ── Activo ── */
  .parish-zone.active .parish-overlay {
    fill: rgba(255, 255, 255, 0.26);
  }
  .parish-zone.active .parish-stroke {
    stroke-width: 18;
    opacity: 1;
    /* Glow de color de identidad de la parroquia */
    filter: drop-shadow(0 0 14px var(--pc)) drop-shadow(0 0 6px rgba(255, 255, 255, 0.8));
  }

  /* ── Accesibilidad (teclado) ── */
  .parish-zone:focus-visible .parish-stroke {
    stroke-width: 16;
    opacity: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .map-root {
      width: 100%;
      max-width: 100%;
      margin: 0 auto;
    }
  }

  /* Reducir movimiento */
  @media (prefers-reduced-motion: reduce) {
    .parish-overlay,
    .parish-stroke {
      transition: none;
    }
  }
</style>
