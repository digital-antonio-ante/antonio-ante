---
/**
 * CantonMapWidget.astro — Mapa SVG interactivo + InfoPanel + Galería.
 *
 * Componente autocontenido: datos, script de coordinación y galería incluidos.
 * Reutilizable en cualquier página sin dependencias externas de estado.
 * Usado en: /parroquias — permite explorar las 6 parroquias interactivamente.
 */
import CantonMapSVG from './CantonMapSVG.astro';
import CantonInfoPanel from './CantonInfoPanel.astro';
import CantonGallery from './CantonGallery.astro';
import { PARISHES } from '../data/parishes';

const parishesJson = JSON.stringify(PARISHES);
---

<div class="map-widget">
  <div class="map-widget-row">
    <div class="map-widget-map">
      <CantonMapSVG />
    </div>
    <div class="map-widget-panel">
      <CantonInfoPanel />
    </div>
  </div>
</div>

<!-- Galería lightbox fuera del widget para z-index correcto -->
<CantonGallery />

<!-- Datos de parroquias serializados en el HTML (sin XHR, CSP-safe) -->
<script id="parish-data" type="application/json" set:html={parishesJson} />

<script>
  import './canton-map-widget';
</script>

<style>
  /* CSS vars: se heredan del contexto padre o se definen aquí como fallback */
  .map-widget {
    --primary: #dc2626;
    --text-main: #0f172a;
    --text-muted: #64748b;
    --surface: #ffffff;
    --surface-border: #e2e8f0;
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    width: 100%;
  }

  /* Layout lado a lado */
  .map-widget-row {
    display: flex;
    gap: 3rem;
    align-items: stretch;
  }

  .map-widget-map {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .map-widget-panel {
    flex: 0 0 370px;
    width: 370px;
    display: flex;
    flex-direction: column;
    align-self: flex-start;
    max-height: 820px;
  }

  .map-widget-panel > * {
    flex: 1;
    height: 100%;
    overflow-y: auto;
  }

  /* Glass panel — aplicado al root de CantonInfoPanel via scope Astro */
  .glass-panel {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 24px;
    box-shadow: var(--shadow-xl);
    overflow: hidden;
  }

  /* Activity chip (creado dinámicamente por JS) */
  :global(.activity-chip) {
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    color: #475569;
    padding: 0.25rem 0.65rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    display: inline-block;
  }

  /* ── Tablet ── */
  @media (min-width: 769px) and (max-width: 1099px) {
    .map-widget-row {
      gap: 2rem;
    }
    .map-widget-panel {
      flex: 0 0 290px;
      width: 290px;
      max-height: none;
    }
    .map-widget-panel > * {
      overflow-y: visible;
    }
  }

  /* ── Móvil ── */
  @media (max-width: 768px) {
    .map-widget-row {
      flex-direction: column;
      gap: 1.5rem;
    }
    .map-widget-panel {
      flex: none;
      width: 100%;
      max-height: none;
    }
    .map-widget-panel > * {
      overflow-y: visible;
    }
  }
</style>
