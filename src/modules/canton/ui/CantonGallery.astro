---
/**
 * CantonGallery.astro — Lightbox de galería de fotos por parroquia.
 *
 * Exponée window.openGallery(name, images, color) para ser invocada desde
 * el script de coordinación en CantonHero.
 * Soporte: teclado (←→ Esc), swipe táctil, thumbnails, spinner de carga.
 */
---

<div
  id="gallery-overlay"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Galería de fotos"
>
  <div class="g-backdrop" id="g-backdrop"></div>

  <div class="g-modal">
    <!-- Header -->
    <div class="g-header">
      <div class="g-header-info">
        <span class="g-dot" id="g-dot" aria-hidden="true"></span>
        <div>
          <p class="g-eyebrow" aria-hidden="true">Galería de fotos</p>
          <h2 class="g-name" id="g-name"></h2>
        </div>
      </div>
      <div class="g-header-actions">
        <span class="g-counter" id="g-counter" aria-live="polite" aria-atomic="true"></span>
        <button class="g-close" id="g-close" aria-label="Cerrar galería">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <!-- Imagen principal -->
    <div class="g-stage">
      <button class="g-arrow g-arrow--prev" id="g-prev" aria-label="Foto anterior">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="g-frame">
        <img id="g-img" src="" alt="" decoding="async" />
        <div class="g-spinner" id="g-spinner" aria-hidden="true">
          <div class="g-spin"></div>
        </div>
      </div>

      <button class="g-arrow g-arrow--next" id="g-next" aria-label="Siguiente foto">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

    <!-- Thumbnails -->
    <div class="g-thumbs" id="g-thumbs"></div>
  </div>
</div>

<style>
  #gallery-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }
  #gallery-overlay.open {
    display: flex;
  }
  .g-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(5, 8, 20, 0.96);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    cursor: pointer;
  }
  .g-modal {
    position: relative;
    z-index: 1;
    width: 92%;
    max-width: 920px;
    max-height: 92vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    animation: g-in 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes g-in {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(16px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Header */
  .g-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .g-header-info {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .g-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .g-eyebrow {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.4);
    line-height: 1;
    margin: 0 0 0.12rem;
  }
  .g-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 800;
    color: white;
    line-height: 1;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .g-header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .g-counter {
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.4);
    font-family: 'Space Grotesk', sans-serif;
  }
  .g-close {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.25s;
  }
  .g-close:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: rotate(90deg);
  }
  .g-close:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  /* Stage */
  .g-stage {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .g-frame {
    flex: 1;
    position: relative;
    background: #0a0f1e;
    border-radius: 14px;
    overflow: hidden;
    height: 62vh;
  }
  .g-frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: opacity 0.25s ease;
  }
  .g-frame img.fading {
    opacity: 0;
  }

  /* Spinner */
  .g-spinner {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(10, 15, 30, 0.5);
  }
  .g-spinner.visible {
    display: flex;
  }
  .g-spin {
    width: 26px;
    height: 26px;
    border: 3px solid rgba(255, 255, 255, 0.15);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.65s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Flechas */
  .g-arrow {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      background 0.2s,
      transform 0.15s;
  }
  .g-arrow:hover {
    background: rgba(255, 255, 255, 0.18);
  }
  .g-arrow:active {
    transform: scale(0.9);
  }
  .g-arrow:disabled {
    opacity: 0.2;
    cursor: default;
  }
  .g-arrow:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  /* Thumbnails */
  .g-thumbs {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    padding: 0 3.5rem;
  }
  .g-thumb {
    flex: 0 0 auto;
    width: 68px;
    height: 44px;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    opacity: 0.45;
    transition:
      opacity 0.2s,
      border-color 0.2s,
      transform 0.2s;
    background: none;
    padding: 0;
  }
  .g-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .g-thumb:hover {
    opacity: 0.75;
    transform: translateY(-2px);
  }
  .g-thumb.active {
    opacity: 1;
    transform: translateY(-2px);
  }
  .g-thumb:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  @media (max-width: 600px) {
    .g-modal {
      width: 97%;
      gap: 0.5rem;
    }
    .g-frame {
      height: 50vh;
    }
    .g-arrow {
      width: 34px;
      height: 34px;
    }
    .g-thumb {
      width: 52px;
      height: 34px;
    }
    .g-thumbs {
      padding: 0 2.5rem;
    }
  }
</style>

<script>
  import './canton-gallery';
</script>
