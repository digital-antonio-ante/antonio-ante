---
/**
 * CantonHero.astro — Sección hero del homepage del portal GAD Antonio Ante.
 *
 * Integra el diseño visual completo del cantón:
 *   - Fondo decorativo (gradiente, orbes de color, silueta montaña, puntos textiles)
 *   - Header animado con título, pills de identidad
 *   - Mapa SVG interactivo + InfoPanel (lado a lado)
 *   - Tira horizontal de tarjetas por parroquia
 *   - Barra de métricas del cantón
 *   - Galería lightbox
 *
 * Coordinación JS: selectParish + event delegation (CSP-safe, sin onclick inline).
 */
import CantonMapSVG from './CantonMapSVG.astro';
import CantonInfoPanel from './CantonInfoPanel.astro';
import ParishCardStrip from './ParishCardStrip.astro';
import CantonGallery from './CantonGallery.astro';
import { PARISHES } from '../data/parishes';
import { getParroquiasImageUrls } from '@api/endpoints/parroquias';
import { getConfigSitio } from '@api/endpoints/config-sitio';

// Fetch en paralelo — ambos son estáticos (prerender = true)
const [sanityParroquias, config] = await Promise.all([
  getParroquiasImageUrls().catch(() => []),
  getConfigSitio().catch(() => null),
]);

// Nombre canónico de cada parroquia en Sanity
const NOMBRE_MAP: Record<string, string> = {
  atuntaqui: 'Atuntaqui',
  andrade_marin: 'Andrade Marín',
  chaltura: 'Chaltura',
  natabuela: 'Natabuela',
  san_roque: 'San Roque',
  imbaya: 'Imbaya',
};

/**
 * Genera una URL de Sanity CDN con crop inteligente basado en el focal point (hotspot).
 * fit=crop + fp-x/fp-y → el CDN recorta en torno al punto importante de la imagen.
 * auto=format → sirve WebP/AVIF según lo que soporte el navegador.
 */
function buildCropUrl(baseUrl: string, w: number, h: number, fpX: number, fpY: number): string {
  return `${baseUrl}?w=${w}&h=${h}&fit=crop&fp-x=${fpX.toFixed(3)}&fp-y=${fpY.toFixed(3)}&auto=format&q=80`;
}

// Mapeo nombre Sanity → datos de imagen con hotspot crudo
const sanityDataByName = Object.fromEntries(
  sanityParroquias.map((p) => {
    const hx = p.hotspotX ?? 0.5;
    const hy = p.hotspotY ?? 0.5;
    return [
      p.nombre,
      {
        url: p.imageUrl ?? null,
        hx,
        hy,
        objectPosition: `${Math.round(hx * 100)}% ${Math.round(hy * 100)}%`,
        // URLs de galería filtradas (sólo las que tienen URL válida)
        galeria: (p.galeria ?? []).filter((g) => g.url).map((g) => g.url as string),
      },
    ];
  })
);

// Merge: dos crops para cada parroquia — portrait para tarjetas, landscape para el panel
const parishes = Object.fromEntries(
  Object.entries(PARISHES).map(([id, data]) => {
    const s = sanityDataByName[NOMBRE_MAP[id] ?? ''];
    if (!s) return [id, data];
    const merged: typeof data = {
      ...data,
      // Galería gestionada desde Sanity; respeta el array estático si Sanity está vacío
      gallery: s.galeria.length > 0 ? s.galeria : data.gallery,
    };
    if (s.url) {
      // 440×640 → ratio portrait ~0.69 — tarjetas verticales (2x retina)
      merged.imageSrc = buildCropUrl(s.url, 440, 640, s.hx, s.hy);
      // 840×400 → ratio landscape 2.1 — panel lateral del mapa (2x retina)
      merged.imageSrcPanel = buildCropUrl(s.url, 840, 400, s.hx, s.hy);
      merged.imageObjectPosition = s.objectPosition;
    }
    return [id, merged];
  })
);

const parishesJson = JSON.stringify(parishes);
const cantonImageUrl = config?.cantonImageUrl ?? null;
const cantonImageAlt = config?.cantonImageAlt ?? 'Cantón Antonio Ante';
const sloganCanton = config?.sloganCanton ?? null;
const descripcionCanton = config?.descripcionCanton ?? null;
const highlightsCanton = config?.highlightsCanton ?? null;
---

<section class="canton-hero-section" aria-label="Bienvenida al Cantón Antonio Ante">
  <!-- ── Header central ── -->
  <header class="canton-header animate-fade-up" aria-label="Presentación del cantón">
    <div class="canton-header-inner">
      <div class="location-pill">
        <span class="location-dot" aria-hidden="true"></span>
        Imbabura · Ecuador
      </div>

      <h1 class="canton-title">
        <span class="canton-title-top">Explora el Cantón</span>
        <span class="canton-title-main">
          Antonio Ante
          <span class="title-underline" aria-hidden="true"></span>
        </span>
      </h1>

      <p class="canton-sub">
        Conoce sus <strong>6 parroquias</strong>, su gente y los proyectos que impulsan la región
      </p>

      <div class="canton-pills" role="list" aria-label="Características del cantón">
        <span class="canton-pill" role="listitem">🧵 Capital Textil</span>
        <span class="canton-pill" role="listitem">🍽️ Gastronomía</span>
        <span class="canton-pill" role="listitem">🏔️ 2.406 m s. n. m.</span>
      </div>
    </div>
  </header>

  <!-- ── Mapa + Panel (lado a lado) ── -->
  <div class="top-row">
    <div class="map-section animate-fade-up" style="animation-delay: 0.1s;">
      <CantonMapSVG />
    </div>
    <div class="info-section animate-fade-up" style="animation-delay: 0.2s;">
      <CantonInfoPanel
        cantonImageUrl={cantonImageUrl}
        cantonImageAlt={cantonImageAlt}
        sloganCanton={sloganCanton}
        descripcionCanton={descripcionCanton}
        highlightsCanton={highlightsCanton}
      />
    </div>
  </div>

  <!-- ── Tira de tarjetas ── -->
  <div class="cards-section animate-fade-up" style="animation-delay: 0.3s;">
    <ParishCardStrip parishes={parishes} />
  </div>
</section>

<!-- Galería lightbox: montada fuera de la sección para z-index correcto -->
<CantonGallery />

<!-- Datos de parroquias inyectados como JSON (no script externo para evitar XHR) -->
<script id="parish-data" type="application/json" set:html={parishesJson} />

<script>
  import './canton-hero';
</script>

<style>
  /* ── CSS custom properties scoped al hero (sin colisión con Tailwind v4) ──
   * Derivadas de los símbolos cantonales:
   *   --primary-green : Verde Esperanza (bandera, franja superior)
   *   --primary-red   : Rojo Patriota   (bandera, franja inferior)
   *   --primary-gold  : Oro Heráldico   (escudo — solo decorativo)
   *   --primary-sky   : Azul Imbabura   (escudo — volcán protector)
   * ─────────────────────────────────────────────────────────────────────── */
  .canton-hero-section {
    --primary: #dc2626; /* Rojo Fuego — dot pulsante, CTAs de acción         */
    --primary-green: #277816; /* Verde Heineken — números, iconos, acentos          */
    --primary-dark: #003109; /* Verde Noche — ancla hero, footer                   */
    --primary-deep: #005d1f; /* Verde Bosque — gradientes intermedios              */
    --primary-vivid: #3c8d2b; /* Verde Brillante — hovers, highlights               */
    --primary-gold: #d97706; /* Amber Andino — barras decorativas                  */
    --bg-body: #f4fbf0; /* Tinte verde Heineken suavísimo */
    --text-main: #003109; /* Verde Noche — máximo contraste */
    --text-muted: #4b5563;
    --surface: #ffffff;
    --surface-border: #d1fae5; /* Borde verde suave */
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);

    position: relative;
    overflow: hidden;
    background: transparent;
    padding: 0 2.5rem;
  }

  /* ── Header ── */
  .canton-header {
    width: 100%;
    padding: 4rem 0 3.5rem;
    text-align: center;
  }
  .canton-header-inner {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }
  .location-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    background: white;
    border: 1px solid var(--surface-border);
    padding: 0.3rem 0.9rem;
    border-radius: 9999px;
    box-shadow: var(--shadow-sm);
  }
  .location-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary);
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(0.6);
    }
  }
  .canton-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
    line-height: 1;
    margin: 0;
  }
  .canton-title-top {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .canton-title-main {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.6rem, 8vw, 4.5rem);
    font-weight: 800;
    color: var(--text-main);
    letter-spacing: -0.03em;
    line-height: 0.95;
    position: relative;
    display: inline-block;
  }
  .title-underline {
    display: block;
    height: 5px;
    /* Verde Bosque → Verde Heineken → Amber → Rojo Fuego: las 5 capas en una línea */
    background: linear-gradient(
      90deg,
      var(--primary-deep),
      var(--primary-green),
      var(--primary-gold),
      var(--primary)
    );
    border-radius: 9999px;
    margin-top: 0.3rem;
    width: 60%;
    margin-left: auto;
    margin-right: auto;
  }
  .canton-sub {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 440px;
    line-height: 1.6;
    margin: 0;
  }
  .canton-sub strong {
    color: var(--text-main);
    font-weight: 700;
  }
  .canton-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
  .canton-pill {
    background: white;
    border: 1px solid var(--surface-border);
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-main);
    box-shadow: var(--shadow-sm);
  }

  /* ── Layout ── */
  .top-row {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    justify-content: center;
    max-width: 1300px;
    margin: 0 auto;
    width: 100%;
  }
  .map-section {
    flex: 1 1 0;
    min-width: 0;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .info-section {
    flex: 1 1 0;
    min-width: 0;
    max-width: 400px;
    display: flex;
    flex-direction: column;
    align-self: flex-start;
  }
  .info-section > * {
    flex: 1;
    height: 100%;
    overflow-y: auto;
  }
  .cards-section {
    margin-top: 4rem;
    max-width: 1300px;
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }

  /* ── Callout de métricas ── */
  .metrics-callout {
    margin-top: 4rem;
    margin-bottom: 4rem;
    max-width: 1300px;
    margin-left: auto;
    margin-right: auto;
  }
  .callout-accent-bar {
    height: 4px;
    background: linear-gradient(
      90deg,
      var(--primary-green) 0%,
      var(--primary-gold) 60%,
      var(--primary) 100%
    );
  }
  .callout-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    padding: 1.75rem 2rem;
  }
  .callout-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .callout-eyebrow {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin: 0;
  }
  .callout-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 800;
    color: var(--text-main);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .callout-sub {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 380px;
    margin: 0.2rem 0 0;
  }
  .callout-metrics {
    display: flex;
    align-items: stretch;
    gap: 0.75rem;
    flex-shrink: 0;
    margin: 0;
  }
  .callout-metric {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: var(--bg-body);
    border: 1px solid var(--surface-border);
    border-radius: 14px;
    padding: 0.75rem 1rem;
    min-width: 105px;
  }
  .callout-metric-icon {
    font-size: 1.3rem;
    flex-shrink: 0;
  }
  .callout-metric > div {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }
  .callout-metric-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--primary-green); /* Esmeralda Viva — #16A34A, 4.54:1 ✓ AA */
    line-height: 1;
    display: block;
  }
  .callout-metric-label {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  /* ── Glass panel ── */
  .glass-panel {
    background: var(--surface);
    border: 1px solid var(--surface-border);
    border-radius: 24px;
    box-shadow: var(--shadow-xl);
    overflow: hidden;
  }

  /* ── Activity chip (generado por JS) ── */
  :global(.activity-chip) {
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    color: #475569;
    padding: 0.25rem 0.65rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    display: inline-block;
  }

  /* ── Animación de entrada ── */
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-up {
    animation: fade-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  /* ── Responsive: tablet ── */
  @media (min-width: 769px) and (max-width: 1099px) {
    .canton-hero-section {
      padding: 0 1.5rem;
    }
    .canton-header {
      padding: 2.5rem 0 2.5rem;
    }
    .top-row {
      gap: 1.5rem;
      align-items: flex-start;
    }
    .map-section {
      max-width: 440px;
    }
    .info-section {
      max-width: 360px;
    }
    .info-section > * {
      overflow-y: visible;
    }
    .cards-section {
      margin-top: 3rem;
    }
    .metrics-callout {
      margin-top: 3rem;
      margin-bottom: 3rem;
    }
  }

  /* ── Responsive: móvil ── */
  @media (max-width: 768px) {
    .canton-hero-section {
      padding: 0 1rem;
    }
    .canton-header {
      padding: 2rem 0 1.75rem;
    }
    .canton-header-inner {
      max-width: 100%;
    }
    .top-row {
      flex-direction: column;
      align-items: stretch;
      gap: 1.5rem;
    }
    .map-section {
      width: 100%;
      max-width: 100%;
    }
    .info-section {
      flex: none;
      width: 100%;
      max-width: 100%;
      max-height: none;
    }
    .info-section > * {
      overflow-y: visible;
    }
    .cards-section {
      margin-top: 2.5rem;
    }
    .metrics-callout {
      margin-top: 2.5rem;
      margin-bottom: 2.5rem;
    }
    .callout-content {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
      padding: 1.25rem;
    }
    .callout-metrics {
      width: 100%;
    }
    .callout-metric {
      flex: 1;
      min-width: 0;
    }
    .callout-sub {
      max-width: 100%;
    }
  }

  /* Reducir movimiento */
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-up {
      animation: none;
      opacity: 1;
    }
    .location-dot {
      animation: none;
    }
  }
</style>
