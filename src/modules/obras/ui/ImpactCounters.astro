---
/**
 * ImpactCounters.astro — Sección dark con métricas de impacto animadas.
 *
 * Los contadores arrancan en 0 y suben al valor real cuando el elemento
 * entra al viewport (IntersectionObserver + requestAnimationFrame).
 * Valores gestionables desde aquí o desde Sanity en el futuro.
 */

const metricas = [
  {
    icono: '🏗️',
    valor: 24,
    sufijo: '',
    label: 'Obras ejecutadas',
    sublabel: 'Período 2024–2028',
  },
  {
    icono: '👨‍👩‍👧',
    valor: 3800,
    sufijo: '+',
    label: 'Familias beneficiadas',
    sublabel: 'En todo el cantón',
  },
  {
    icono: '🛣️',
    valor: 47,
    sufijo: ' km',
    label: 'Vías mejoradas',
    sublabel: 'Asfaltado y adoquinado',
  },
  {
    icono: '💵',
    prefijo: '$',
    valor: 5.2,
    sufijo: 'M',
    decimales: 1,
    label: 'Millones invertidos',
    sublabel: 'En proyectos activos',
  },
];
---

<section class="impact-section" aria-labelledby="impact-heading">
  <div class="impact-inner">
    <div class="impact-header">
      <p class="impact-eyebrow">Resultados que se ven</p>
      <h2 id="impact-heading" class="impact-title">Gestión en números</h2>
    </div>

    <dl class="impact-grid" aria-label="Métricas de impacto del cantón">
      {
        metricas.map((m, i) => (
          <div class="impact-card" style={`animation-delay: ${i * 0.1}s`}>
            <span class="impact-icon" aria-hidden="true">
              {m.icono}
            </span>
            <dd
              class="impact-num"
              data-target={m.valor}
              data-suffix={m.sufijo ?? ''}
              data-prefix={m.prefijo ?? ''}
              data-decimals={m.decimales ?? 0}
              aria-label={`${m.prefijo ?? ''}${m.valor}${m.sufijo ?? ''} ${m.label}`}
            >
              {m.prefijo ?? ''}0{m.sufijo ?? ''}
            </dd>
            <dt class="impact-label">{m.label}</dt>
            <span class="impact-sublabel">{m.sublabel}</span>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<script>
  // ── Contador animado con easeOut cúbico ────────────────────────────────────
  function easeOut(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  function animateCounter(el: HTMLElement): void {
    const target = parseFloat(el.dataset.target ?? '0');
    const suffix = el.dataset.suffix ?? '';
    const prefix = el.dataset.prefix ?? '';
    const decimals = parseInt(el.dataset.decimals ?? '0', 10);
    const duration = 2000;
    const start = performance.now();

    function update(now: number): void {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const value = easeOut(progress) * target;
      const formatted =
        decimals > 0 ? value.toFixed(decimals) : Math.round(value).toLocaleString('es-EC');
      el.textContent = `${prefix}${formatted}${suffix}`;
      if (progress < 1) requestAnimationFrame(update);
    }

    requestAnimationFrame(update);
  }

  // ── IntersectionObserver — anima solo cuando entra al viewport ─────────────
  const counters = document.querySelectorAll<HTMLElement>('[data-target]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.4 }
  );

  counters.forEach((el) => observer.observe(el));
</script>

<style>
  .impact-section {
    background: linear-gradient(160deg, #003109 0%, #005d1f 55%, #003109 100%);
    padding: 0 1.5rem 2.75rem;
    position: relative;
    overflow: hidden;
  }

  /* Barra de acento tricolor superior — misma que en el callout cantonal */
  .impact-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #277816 0%, #d97706 55%, #dc2626 100%);
    pointer-events: none;
  }

  /* Orbe decorativo ámbar tenue en esquina inferior izquierda */
  .impact-section::after {
    content: '';
    position: absolute;
    bottom: -80px;
    left: -60px;
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, rgba(217, 119, 6, 0.18) 0%, transparent 68%);
    pointer-events: none;
  }

  .impact-inner {
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding-top: 2.75rem;
  }

  /* Header — más compacto */
  .impact-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .impact-eyebrow {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #fbbf24;
    margin: 0 0 0.35rem;
  }
  .impact-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.03em;
    margin: 0;
    line-height: 1.1;
  }

  /* Grid — sin gaps visibles, solo separadores entre items */
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 0;
  }

  /* Card — sin fondo ni borde propio, divisor vertical entre items */
  .impact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.25rem 1rem;
    gap: 0.2rem;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    transition: background 0.2s ease;
  }
  .impact-card:last-child {
    border-right: none;
  }
  .impact-card:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .impact-icon {
    font-size: 1.25rem;
    line-height: 1;
    margin-bottom: 0.35rem;
    opacity: 0.85;
  }
  .impact-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    font-weight: 800;
    background: linear-gradient(135deg, #ffffff 30%, #fbbf24 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin: 0;
    letter-spacing: -0.03em;
  }
  .impact-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.8);
    margin: 0.15rem 0 0;
    line-height: 1.2;
  }
  .impact-sublabel {
    font-size: 0.62rem;
    color: rgba(255, 255, 255, 0.38);
    font-weight: 500;
    margin-top: 0.05rem;
  }

  /* Responsive */
  @media (max-width: 700px) {
    .impact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .impact-card:nth-child(2) {
      border-right: none;
    }
    .impact-card:nth-child(3),
    .impact-card:nth-child(4) {
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }
  }
  @media (max-width: 480px) {
    .impact-section {
      padding: 0 1rem 2rem;
    }
    .impact-inner {
      padding-top: 2rem;
    }
    .impact-card {
      padding: 1rem 0.75rem;
    }
    .impact-icon {
      font-size: 1.1rem;
    }
  }
</style>
