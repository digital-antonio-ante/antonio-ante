---
/**
 * ObrasGrid.astro — Grid de obras municipales en marcha.
 *
 * Reemplaza las secciones "Noticias" y "Documentos" del homepage anterior.
 * Muestra hasta 6 obras con imagen, categoría, parroquia, descripción breve
 * y barra de progreso animada al entrar al viewport.
 *
 * Estado vacío: placeholder que invita a cargar obras desde Sanity.
 */
import type { Obra } from '@api/endpoints/obras';

interface Props {
  obras: Obra[];
}

const { obras } = Astro.props;

// Metadatos visuales por categoría
const CATEGORIA: Record<string, { label: string; color: string; bg: string }> = {
  vialidad: { label: 'Vialidad', color: '#1d4ed8', bg: '#dbeafe' },
  agua: { label: 'Agua y saneamiento', color: '#0369a1', bg: '#e0f2fe' },
  educacion: { label: 'Educación', color: '#6d28d9', bg: '#ede9fe' },
  salud: { label: 'Salud', color: '#b91c1c', bg: '#fee2e2' },
  espacios_publicos: { label: 'Espacios públicos', color: '#15803d', bg: '#dcfce7' },
  productividad: { label: 'Productividad', color: '#b45309', bg: '#fef3c7' },
  cultura: { label: 'Cultura y deporte', color: '#7c3aed', bg: '#f3e8ff' },
};

const ESTADO: Record<string, { label: string; color: string }> = {
  planificada: { label: 'Planificada', color: '#6b7280' },
  en_progreso: { label: 'En progreso', color: '#2563eb' },
  completada: { label: 'Completada', color: '#15803d' },
};

function formatUSD(n: number): string {
  if (n >= 1_000_000) return `$${(n / 1_000_000).toFixed(1)}M`;
  if (n >= 1_000) return `$${Math.round(n / 1_000)}k`;
  return `$${n.toLocaleString('es-EC')}`;
}
---

<section class="obras-section" aria-labelledby="obras-heading">
  <div class="obras-inner">
    <!-- Header -->
    <div class="obras-header">
      <div>
        <p class="obras-eyebrow">Gestión Municipal 2024–2028</p>
        <h2 id="obras-heading" class="obras-title">Obras en marcha</h2>
        <p class="obras-sub">Inversión pública que transforma cada rincón del cantón.</p>
      </div>
      {
        obras.length > 0 && (
          <span class="obras-count" aria-label={`${obras.length} obras mostradas`}>
            {obras.length} {obras.length === 1 ? 'obra' : 'obras'}
          </span>
        )
      }
    </div>

    <!-- Grid de obras -->
    {
      obras.length > 0 ? (
        <ul class="obras-grid" role="list">
          {obras.map((obra) => {
            const cat = CATEGORIA[obra.categoria] ?? {
              label: obra.categoria,
              color: '#6b7280',
              bg: '#f3f4f6',
            };
            const est = ESTADO[obra.estado] ?? { label: obra.estado, color: '#6b7280' };
            const avance = Math.max(0, Math.min(100, obra.porcentajeAvance));

            return (
              <li>
                <a
                  href={`/obras/${obra.slug.current}`}
                  class="obra-card"
                  aria-label={`Ver detalle: ${obra.titulo}`}
                >
                  <div class="obra-img-wrap">
                    {obra.imageUrl ? (
                      <img
                        src={`${obra.imageUrl}?w=600&h=340&fit=crop&auto=format&q=80`}
                        alt={obra.imageAlt ?? obra.titulo}
                        class="obra-img"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div
                        class="obra-img-fallback"
                        style={`background: linear-gradient(135deg, ${cat.color}22, ${cat.color}55);`}
                        aria-hidden="true"
                      >
                        <span class="obra-img-fallback-icon">🏗️</span>
                      </div>
                    )}
                    <div class="obra-badges">
                      <span
                        class="obra-cat-badge"
                        style={`background:${cat.bg}; color:${cat.color};`}
                      >
                        {cat.label}
                      </span>
                      <span
                        class="obra-estado-badge"
                        style={`background:${est.color}; color:#fff;`}
                      >
                        {est.label}
                      </span>
                    </div>
                  </div>

                  <div class="obra-body">
                    <p class="obra-parroquia">
                      <svg
                        width="11"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" />
                      </svg>
                      {obra.parroquia}
                    </p>

                    <h3 class="obra-titulo">{obra.titulo}</h3>
                    <p class="obra-resumen">{obra.resumen}</p>

                    <div class="obra-progress" aria-label={`Avance: ${avance}%`}>
                      <div class="progress-meta">
                        <span>Avance</span>
                        <strong style={`color:${cat.color}`}>{avance}%</strong>
                      </div>
                      <div
                        class="progress-track"
                        role="progressbar"
                        aria-valuenow={avance}
                        aria-valuemin={0}
                        aria-valuemax={100}
                      >
                        <div
                          class="progress-fill"
                          style={`width:${avance}%; background:${cat.color};`}
                          data-width={avance}
                        />
                      </div>
                    </div>

                    {(obra.presupuestoUSD || obra.familiasBeneficiadas) && (
                      <div class="obra-chips">
                        {obra.presupuestoUSD && (
                          <span class="obra-chip">💵 {formatUSD(obra.presupuestoUSD)}</span>
                        )}
                        {obra.familiasBeneficiadas && (
                          <span class="obra-chip">
                            👨‍👩‍👧 {obra.familiasBeneficiadas.toLocaleString('es-EC')} familias
                          </span>
                        )}
                      </div>
                    )}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      ) : (
        <div class="obras-empty">
          <span class="obras-empty-icon" aria-hidden="true">
            🏗️
          </span>
          <h3 class="obras-empty-title">Próximamente</h3>
          <p class="obras-empty-desc">
            Estamos cargando las obras del cantón. Vuelve pronto para conocer los proyectos en
            ejecución.
          </p>
        </div>
      )
    }
  </div>
</section>

<script>
  // Anima las barras de progreso al entrar al viewport
  const fills = document.querySelectorAll<HTMLElement>('.progress-fill');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = el.dataset.width ?? '0';
          // Reset y anima
          el.style.width = '0%';
          requestAnimationFrame(() => {
            el.style.transition = 'width 1.2s cubic-bezier(0.16, 1, 0.3, 1)';
            el.style.width = `${target}%`;
          });
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.3 }
  );
  fills.forEach((el) => observer.observe(el));
</script>

<style>
  /* ── Sección ── */
  .obras-section {
    padding: 5rem 0;
    background: transparent;
  }
  .obras-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .obras-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .obras-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #b45309;
    margin: 0 0 0.4rem;
  }
  .obras-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #111827;
    letter-spacing: -0.02em;
    margin: 0 0 0.4rem;
    line-height: 1.1;
  }
  .obras-sub {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0;
  }
  .obras-count {
    font-size: 0.75rem;
    font-weight: 700;
    color: #9ca3af;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    padding: 0.3rem 0.8rem;
    border-radius: 9999px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Grid */
  .obras-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Card */
  .obra-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }
  .obra-card:hover {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    transform: translateY(-3px);
  }

  /* Imagen */
  .obra-img-wrap {
    position: relative;
    width: 100%;
    height: 200px;
    flex-shrink: 0;
    background: #f1f5f9;
    overflow: hidden;
  }
  .obra-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .obra-card:hover .obra-img {
    transform: scale(1.04);
  }
  .obra-img-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .obra-img-fallback-icon {
    font-size: 3rem;
    opacity: 0.5;
  }

  /* Badges */
  .obra-badges {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    right: 0.75rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .obra-cat-badge,
  .obra-estado-badge {
    font-size: 0.58rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.22rem 0.6rem;
    border-radius: 9999px;
    line-height: 1.4;
    backdrop-filter: blur(4px);
  }

  /* Body */
  .obra-body {
    flex: 1;
    padding: 1.1rem 1.2rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .obra-parroquia {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #9ca3af;
    margin: 0;
  }
  .obra-parroquia svg {
    flex-shrink: 0;
    opacity: 0.6;
  }
  .obra-titulo {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 800;
    color: #111827;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .obra-resumen {
    font-size: 0.82rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Progress */
  .obra-progress {
    margin-top: auto;
    padding-top: 0.4rem;
  }
  .progress-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.7rem;
    font-weight: 600;
    color: #9ca3af;
    margin-bottom: 0.4rem;
  }
  .progress-meta strong {
    font-size: 0.75rem;
  }
  .progress-track {
    height: 6px;
    background: #f1f5f9;
    border-radius: 9999px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 9999px;
    width: 0%;
  }

  /* Chips */
  .obra-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.2rem;
  }
  .obra-chip {
    font-size: 0.68rem;
    font-weight: 600;
    color: #6b7280;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    padding: 0.22rem 0.65rem;
    border-radius: 9999px;
  }

  /* Estado vacío */
  .obras-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 2rem;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 2px dashed #d1fae5;
    border-radius: 20px;
  }
  .obras-empty-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }
  .obras-empty-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem;
    font-weight: 800;
    color: #374151;
    margin: 0 0 0.5rem;
  }
  .obras-empty-desc {
    font-size: 0.875rem;
    color: #9ca3af;
    max-width: 360px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .obras-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .obras-section {
      padding: 3.5rem 0;
    }
    .obras-inner {
      padding: 0 1rem;
    }
    .obras-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .obras-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .obra-img-wrap {
      height: 180px;
    }
  }
</style>
