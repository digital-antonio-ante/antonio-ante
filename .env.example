# ─── Sanity.io (required) ─────────────────────────────────────────────────────
PUBLIC_SANITY_PROJECT_ID=your_project_id_here
PUBLIC_SANITY_DATASET=production

# ─── Sanity.io (optional — for draft preview or private datasets) ────────────
# SANITY_API_TOKEN=your_token_here

# ─── Environment ─────────────────────────────────────────────────────────────
# Set to "production" in Netlify env vars. Any other value triggers noindex.
APP_ENV=development
