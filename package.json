{
  "name": "antonio-ante",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "validate:seo": "tsx scripts/validate-seo.ts",
    "validate:bundle": "tsx scripts/validate-bundle-size.ts",
    "validate": "npm run validate:seo && npm run validate:bundle",
    "ci": "npm run typecheck && npm run lint && npm run build && npm run validate",
    "studio:dev": "npm run dev --prefix studio",
    "studio:build": "npm run build --prefix studio",
    "studio:deploy": "npm run deploy --prefix studio",
    "studio:seed": "SANITY_API_TOKEN=$SANITY_API_TOKEN tsx studio/scripts/seed.ts"
  },
  "lint-staged": {
    "*.{js,ts,astro}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.6",
    "@sanity/client": "^7.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "astro": "^6.1.5",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
